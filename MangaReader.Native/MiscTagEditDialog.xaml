<Window x:Class="MangaReader.Native.MiscTagEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="杂图标签"
        Width="520"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}"/>
                    <TextBlock x:Name="DialogTitle" Text="新建杂图标签" Style="{StaticResource AppDialogTitleText}"/>
                </DockPanel>

                <StackPanel Grid.Row="1" Margin="0,18,0,0">
                    <TextBlock x:Name="UsageCountText"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="12"
                               Margin="0,0,0,14"
                               Visibility="Collapsed"/>

                    <TextBlock Text="标签名称" Style="{StaticResource AppDialogLabelText}"/>
                    <TextBox x:Name="TagNameBox"
                             Margin="0,8,0,0"
                             Style="{StaticResource AppDialogTextBox}"/>

                    <TextBlock Text="标签分组（可输入自定义）"
                               Style="{StaticResource AppDialogLabelText}"
                               Margin="0,18,0,0"/>
                    <ComboBox x:Name="TagCategoryBox"
                              Margin="0,8,0,0"
                              IsEditable="True"
                              SelectionChanged="TagCategoryBox_Changed"
                              LostFocus="TagCategoryBox_LostFocus"
                              Style="{StaticResource AppDialogEditableComboBox}"/>

                    <TextBlock Text="标签颜色"
                               Style="{StaticResource AppDialogLabelText}"
                               Margin="0,18,0,0"/>
                    <WrapPanel Margin="0,10,0,0" VerticalAlignment="Top">
                        <ItemsControl x:Name="PresetColorPicker">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ColorSwatchBorderStyle}"
                                            Background="{Binding}"
                                            MouseLeftButtonDown="ColorSwatch_Click"
                                            Margin="0,0,8,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Style="{StaticResource AddColorSwatchBorderStyle}"
                                Margin="0,0,8,0"
                                MouseLeftButtonDown="AddCustomColor_Click"
                                ToolTip="添加自定义颜色">
                            <TextBlock Text="+"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </WrapPanel>
                    <Border x:Name="SelectedColorPreview"
                            Margin="0,10,0,0"
                            Padding="12,6"
                            CornerRadius="{StaticResource RadiusTag}"
                            HorizontalAlignment="Left"
                            SnapsToDevicePixels="True">
                        <TextBlock x:Name="SelectedColorText"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.TextPrimary}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,18,0,8">
                    <Button Content="取消"
                            Width="104"
                            Margin="0,0,10,0"
                            Click="Cancel_Click"
                            Style="{StaticResource AppDialogGhostButton}"/>
                    <Button x:Name="ConfirmButton"
                            Content="保存"
                            Width="104"
                            Click="Confirm_Click"
                            Style="{StaticResource AppDialogButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
