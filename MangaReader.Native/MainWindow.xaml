<Window x:Class="MangaReader.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:MangaReader.Native.Controls"
        xmlns:models="clr-namespace:MangaReader.Native.Models"
        mc:Ignorable="d"
        Title="漫画库" Height="900" Width="1500" MinHeight="760" MinWidth="1180"
        Background="{StaticResource Brush.AppBackground}" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <DropShadowEffect x:Key="BookShadow" Color="#111827" BlurRadius="18" ShadowDepth="6" Opacity="0.14"/>
        <DropShadowEffect x:Key="PanelShadow" Color="#111827" BlurRadius="28" ShadowDepth="10" Opacity="0.08"/>

        <Style TargetType="Button" BasedOn="{StaticResource AppButton}"/>
        <Style x:Key="HomeWideBookCard" TargetType="Border">
            <Setter Property="Height" Value="208"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusPanel}"/>
            <Setter Property="Background" Value="#26201B"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#F6E7D6"/>
                    <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
                    <Setter Property="Opacity" Value="0.96"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HomeCompactBookCard" TargetType="Border">
            <Setter Property="Width" Value="286"/>
            <Setter Property="Height" Value="104"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusPanel}"/>
            <Setter Property="Background" Value="#FDFBF8"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#D8C7B8"/>
                    <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HomeBookActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="#F6E7D6"/>
            <Setter Property="Foreground" Value="#1D1714"/>
            <Setter Property="BorderBrush" Value="#D8C7B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="FilterActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Brush.BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusField}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TinyButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="DetailActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="DetailPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource AppButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="DetailDangerActionButton" TargetType="Button" BasedOn="{StaticResource AppDangerButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="AppTagChipBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="{StaticResource RadiusControl}"/>
            <Setter Property="BorderBrush" Value="#D4DCE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,7,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#64748B"/>
                    <Setter Property="Opacity" Value="0.88"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CardTagChipBorder" TargetType="Border">
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusControl}"/>
            <Setter Property="BorderBrush" Value="#D4DCE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Margin" Value="0,0,5,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#64748B"/>
                    <Setter Property="Opacity" Value="0.88"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AppTagChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#263238"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BatchActionButton" TargetType="Button" BasedOn="{StaticResource TinyButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>
        <Style x:Key="HeaderActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SlimProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource Brush.BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusProgress}"/>
                            <Border x:Name="PART_Track" CornerRadius="{StaticResource RadiusProgress}"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource RadiusProgress}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusField}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9CA3AF"/>
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="13,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusField}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C4CCD7"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9CA3AF"/>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Surface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" SnapsToDevicePixels="True">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusField}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="16,0,4,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Grid Grid.Column="1">
                                        <Path Data="M 0 0 L 4 4 L 8 0"
                                              Stroke="#6B7280"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=ComboRoot}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,6,0,0"
                                        Width="{Binding ActualWidth, ElementName=ComboRoot}"
                                        Background="{StaticResource Brush.Surface}"
                                        BorderBrush="{StaticResource Brush.BorderStrong}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusField}"
                                        Effect="{StaticResource PanelShadow}">
                                    <ScrollViewer MaxHeight="280"
                                                  CanContentScroll="True">
                                        <ItemsPresenter Margin="4"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#C4CCD7"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="FilterComboBox_PreviewMouseLeftButtonDown"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" SnapsToDevicePixels="True">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusField}">
                                <Grid Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Border Grid.Column="1"
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,10,0"
                                            Background="#EEF2F7"
                                            CornerRadius="{StaticResource RadiusControl}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                        <Path Data="M 0 0 L 5 5 L 10 0"
                                              Stroke="#6B7280"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=ComboRoot}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,8,0,0"
                                        Width="{Binding ActualWidth, ElementName=ComboRoot}"
                                        Background="{StaticResource Brush.Surface}"
                                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Effect="{StaticResource PanelShadow}">
                                    <ScrollViewer MaxHeight="280" CanContentScroll="True">
                                        <ItemsPresenter Margin="6"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#9CA3AF"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusPanel}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#E5E7EB"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemRoot" Property="Background" Value="#DDE3EA"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="CheckRoot"
                                MinHeight="36"
                                Padding="12,7"
                                Background="{StaticResource Brush.SurfaceMuted}"
                                BorderBrush="{StaticResource Brush.BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusControl}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="CheckMark"
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,8,0"
                                        Background="#FFFFFF"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusClip}">
                                    <Path x:Name="CheckGlyph"
                                          Data="M 4 9 L 7 12 L 14 5"
                                          Stroke="#FFFFFF"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckRoot" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="CheckRoot" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckRoot" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="CheckRoot" Property="BorderBrush" Value="#C7D2FE"/>
                                <Setter TargetName="CheckMark" Property="Background" Value="#111827"/>
                                <Setter TargetName="CheckMark" Property="BorderBrush" Value="#111827"/>
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BatchSelectCheckBox" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="SelectRoot"
                                Width="30"
                                Height="30"
                                Background="#DDF8FAFC"
                                BorderBrush="#94A3B8"
                                BorderThickness="1.2"
                                CornerRadius="{StaticResource RadiusControl}">
                            <Grid>
                                <Ellipse x:Name="SelectDot"
                                         Width="16"
                                         Height="16"
                                         Fill="Transparent"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                                <Path x:Name="SelectGlyph"
                                      Data="M 5 10 L 8 13 L 15 6"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectRoot" Property="Background" Value="#EEF2F7"/>
                                <Setter TargetName="SelectRoot" Property="BorderBrush" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SelectRoot" Property="Background" Value="#111827"/>
                                <Setter TargetName="SelectRoot" Property="BorderBrush" Value="#111827"/>
                                <Setter TargetName="SelectDot" Property="Fill" Value="#111827"/>
                                <Setter TargetName="SelectGlyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusPanel}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="SidebarNavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="132"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="SidebarActionButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
        </Style>
        <Style x:Key="SidebarLogToggleButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
        </Style>
        <Style x:Key="LibraryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="214"/>
            <Setter Property="Height" Value="378"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SelectionFrame" Padding="4" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusPanel}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectionFrame" Property="Background" Value="#0D111827"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionFrame" Property="Background" Value="#18111827"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SelectionFrame" Property="Background" Value="#24111827"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="LibraryBookTemplate">
            <Border x:Name="LibraryBookCard"
                    Width="198"
                    Height="360"
                    Padding="12"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    MouseEnter="BookCard_MouseEnter"
                    MouseLeave="BookCard_MouseLeave"
                    PreviewMouseLeftButtonDown="BookCard_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="BookCard_PreviewMouseLeftButtonUp"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <StackPanel>
                    <Grid Width="162" Height="220" HorizontalAlignment="Center">
                        <Grid Width="150" Height="214" VerticalAlignment="Top" Effect="{StaticResource BookShadow}">
                            <Grid x:Name="GrooveCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border CornerRadius="{StaticResource RadiusProgress}" ClipToBounds="True" Background="Transparent">
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>
                                <Rectangle Width="3" Margin="34,12,0,12" HorizontalAlignment="Left" Fill="#66000000" RadiusX="1.5" RadiusY="1.5"/>
                                <Rectangle Width="1" Margin="39,14,0,14" HorizontalAlignment="Left" Fill="#66FFFFFF" RadiusX="1" RadiusY="1"/>
                            </Grid>

                            <Grid x:Name="BoundMangaCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="1">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border CornerRadius="{StaticResource RadiusClip}" ClipToBounds="True" Background="Transparent">
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>
                                <Border Width="42" HorizontalAlignment="Left" CornerRadius="{StaticResource RadiusClipLeft}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#70000000" Offset="0"/>
                                            <GradientStop Color="#26000000" Offset="0.48"/>
                                            <GradientStop Color="#24FFFFFF" Offset="0.66"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Rectangle Width="12" HorizontalAlignment="Left" Margin="27,5,0,5" RadiusX="6" RadiusY="6" Opacity="0.38">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00000000" Offset="0"/>
                                            <GradientStop Color="#55FFFFFF" Offset="0.55"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>

                            <Grid x:Name="PlainCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="2">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border CornerRadius="{StaticResource RadiusClip}" ClipToBounds="True" Background="Transparent">
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>
                            </Grid>

                            <Grid x:Name="WhiteBorderCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="3">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border Background="#FAFFFFFF" CornerRadius="{StaticResource RadiusProgress}" Padding="7">
                                    <Border CornerRadius="{StaticResource RadiusClip}" ClipToBounds="True" Background="Transparent">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>
                                </Border>
                            </Grid>
                        </Grid>
                        <Border Padding="8,4"
                                CornerRadius="{StaticResource RadiusControl}"
                                Background="#F8E7B4"
                                BorderBrush="#E4B95F"
                                BorderThickness="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,4,2,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="★" Foreground="#F59E0B" FontSize="14"/>
                        </Border>
                        <CheckBox IsChecked="{Binding IsSelectedForBatch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource BatchSelectCheckBox}"
                                  Visibility="{Binding IsBatchSelectionUiVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                                  Checked="BatchSelection_Changed"
                                  Unchecked="BatchSelection_Changed"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Margin="6,6,0,0"/>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding Title}" FontWeight="Black" FontSize="14" Foreground="#25211E" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                        <TextBlock Text="{Binding Author}" Margin="0,4,0,0" Foreground="#81756B" FontSize="12" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                        <TextBlock Text="{Binding LibraryMetaText}" Margin="0,7,0,0" Foreground="#7E6A58" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding MissingText}" Foreground="#B44A36" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,6,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding HiddenText}" Foreground="#9A6F25" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,6,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding CardTagItems}" Margin="0,8,0,0" MaxHeight="44" ClipToBounds="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardTagChipBorder}"
                                            MaxWidth="170"
                                            Background="{Binding Color}"
                                            MouseEnter="TagChip_MouseEnter"
                                            MouseLeave="TagChip_MouseLeave"
                                            PreviewMouseLeftButtonDown="TagChip_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="TagChip_PreviewMouseLeftButtonUp"
                                            MouseMove="TagChip_MouseMove"
                                            MouseLeftButtonDown="TagChip_MouseLeftButtonDown">
                                        <TextBlock Text="{Binding Name}"
                                                   MaxWidth="148"
                                                   Style="{StaticResource AppTagChipText}"
                                                   FontSize="10"
                                                   LineHeight="12"
                                                   LineStackingStrategy="BlockLineHeight"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HomeWideBookTemplate">
            <Border Style="{StaticResource HomeWideBookCard}"
                    MouseLeftButtonDown="HomeBook_Click"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2D241E" Offset="0"/>
                            <GradientStop Color="#171310" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill" Opacity="0.34"/>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#E61C1713" Offset="0"/>
                                <GradientStop Color="#B8191512" Offset="0.52"/>
                                <GradientStop Color="#33110D0A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Grid Margin="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="104"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="92" Height="138" CornerRadius="{StaticResource RadiusPanel}" Background="{Binding BookAccentColor}" ClipToBounds="True" VerticalAlignment="Center" Effect="{StaticResource BookShadow}">
                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                        </Border>
                        <Grid Grid.Column="1" Margin="12,4,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="继续阅读" Foreground="#CFB9A6" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="{Binding Title}" Margin="0,10,0,0" Foreground="#FAF5EF" FontSize="22" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="2" Text="{Binding Author}" Margin="0,7,0,0" Foreground="#D6C7BA" FontSize="13" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="3" Text="{Binding ReadingMetaText}" Margin="0,12,0,0" Foreground="#F0E5DA" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Row="4"
                                    Content="查看详情"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource HomeBookActionButton}"
                                    Click="HomeBookButton_Click"/>
                        </Grid>
                    </Grid>
                    <Border Padding="9,5"
                            CornerRadius="{StaticResource RadiusControl}"
                            Background="#F8E7B4"
                            BorderBrush="#E4B95F"
                            BorderThickness="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,14,14,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="★" Foreground="#F59E0B" FontSize="14"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HomeCompactBookTemplate">
            <Border Style="{StaticResource HomeCompactBookCard}"
                    MouseLeftButtonDown="HomeBook_Click"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="68" Height="84" CornerRadius="{StaticResource RadiusPanel}" Background="{Binding BookAccentColor}" ClipToBounds="True" VerticalAlignment="Center">
                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                    </Border>
                    <Border Padding="6,2"
                            CornerRadius="{StaticResource RadiusControl}"
                            Background="#F8E7B4"
                            BorderBrush="#E4B95F"
                            BorderThickness="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="48,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="★" Foreground="#F59E0B" FontSize="12"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,4,0,0">
                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Black" Foreground="#25211E" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Author}" Margin="0,4,0,0" Foreground="#7B7068" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding ReadingMetaText}" Margin="0,6,0,0" Foreground="#9A5A36" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0"/>
                <GradientStop Color="#F3F4F6" Offset="0.55"/>
                <GradientStop Color="#EEF2F7" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="DetailColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="18" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" Effect="{StaticResource PanelShadow}">
            <DockPanel LastChildFill="True">
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,24">
                            <Border Width="46" Height="46" CornerRadius="{StaticResource RadiusControl}">
                                <Border.Background>
                                    <ImageBrush ImageSource="pack://application:,,,/Assets/icon.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border.Background>
                            </Border>
                            <StackPanel Margin="12,2,0,0">
                                <TextBlock Text="漫画库" FontSize="21" FontWeight="Black" Foreground="#25211E"/>
                                <TextBlock x:Name="VersionText" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,18">
                            <Border Height="32" CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource Brush.ScrollTrack}" Margin="8,0,8,10">
                                <TextBlock Text="浏览"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                            <Button x:Name="HomeNavButton" Content="主页" Click="NavHome_Click" Style="{StaticResource SidebarNavButton}"/>
                            <Button x:Name="LibraryNavButton" Content="书库" Click="NavLibrary_Click" Style="{StaticResource SidebarNavButton}"/>
                            <Button x:Name="TagsNavButton" Content="标签" Click="NavTags_Click" Style="{StaticResource SidebarNavButton}"/>
                            <Button x:Name="AuthorsNavButton" Content="作者" Click="NavAuthors_Click" Style="{StaticResource SidebarNavButton}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,18">
                            <Border Height="32" CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource Brush.ScrollTrack}" Margin="8,0,8,10">
                                <TextBlock Text="工具"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                            <StackPanel Width="132" HorizontalAlignment="Center">
                                <Button Content="指定数据" Click="ChooseDataFolder_Click" Style="{StaticResource SidebarActionButton}"/>
                                <Button Content="备份数据" Click="DataSafety_Click" Style="{StaticResource SidebarActionButton}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,8">
                            <Border Height="32" CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource Brush.ScrollTrack}" Margin="8,0,8,10">
                                <TextBlock Text="调试"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                            <StackPanel Width="132" HorizontalAlignment="Center">
                                <Button Content="检查更新" Click="CheckUpdate_Click" Style="{StaticResource SidebarActionButton}"/>
                                <Button x:Name="LogPanelToggleButton"
                                        Content="展开日志"
                                        Click="ToggleStatusPanel_Click"
                                        Style="{StaticResource SidebarActionButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="0,26,0,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="HomePagePanel">
                <ScrollViewer x:Name="HomeMainScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                    <StackPanel Margin="8,0,22,12">
                        <Border x:Name="HomeEmptyState" Padding="26" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" Effect="{StaticResource PanelShadow}" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="先导入一本漫画" FontSize="30" FontWeight="Black" Foreground="#111827"/>
                                    <TextBlock x:Name="HomeIntroText" Text="首页只有在有内容时才应该存在。现在先导入一本漫画，后面才会出现继续阅读、收藏和最近加入。" Margin="0,10,0,0" Foreground="#6B7280" FontSize="15" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <Button Content="导入漫画" Click="ChooseLibrary_Click" Margin="0,0,10,0"/>
                                    <Button Content="去漫画库" Click="NavLibrary_Click" Style="{StaticResource AppGhostButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="HomeSectionsPanel">
                        <Border Padding="18"
                                CornerRadius="{StaticResource RadiusPanel}"
                                Background="#FFFFFF"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Effect="{StaticResource PanelShadow}">
                            <StackPanel>
                                <TextBlock Text="继续阅读" Margin="4,0,0,14" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                                <ItemsControl ItemsSource="{Binding ContinueReadingBooks}" ItemTemplate="{StaticResource HomeWideBookTemplate}">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Margin" Value="0,0,12,0"/>
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            <Setter Property="VerticalAlignment" Value="Stretch"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <TextBlock x:Name="ContinueReadingEmptyText" Text="还没有可继续阅读的漫画，先打开一本书，主页就会把它放在这里。" Margin="4,10,0,0" Foreground="#8A7F77" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="之前读过" Margin="4,28,0,14" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding RecentReadingBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="RecentReadingEmptyText" Text="还没有阅读记录，读过的漫画会出现在这里。" Margin="4,10,0,0" Foreground="#8A7F77" Visibility="Collapsed"/>

                        <TextBlock Text="收藏" Margin="4,28,0,14" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding FavoriteShowcaseBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="FavoriteShowcaseEmptyText" Text="还没有收藏作品，先在书库里挑几本真正想反复回看的漫画。" Margin="4,10,0,0" Foreground="#8A7F77" Visibility="Collapsed"/>

                        <TextBlock Text="最近加入" Margin="4,28,0,14" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PreviewMouseWheel="HorizontalShelfScrollViewer_PreviewMouseWheel">
                            <ItemsControl ItemsSource="{Binding RecentlyAddedBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="RecentlyAddedEmptyText" Text="这里还没有新加入的漫画，导入书库后会自动出现。" Margin="4,10,0,0" Foreground="#8A7F77" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="LibraryPagePanel"
                  Visibility="Collapsed"
                  Background="Transparent"
                  MouseDown="LibraryArea_MouseDown"
                  AllowDrop="True"
                  DragEnter="LibraryPagePanel_DragEnter"
                  DragOver="LibraryPagePanel_DragOver"
                  DragLeave="LibraryPagePanel_DragLeave"
                  Drop="LibraryPagePanel_Drop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="LibraryFilterPanel" Grid.Row="0" Margin="8,0,22,16" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FilterSummaryText" Text="当前显示全部漫画" VerticalAlignment="Center" Foreground="#B45309" FontSize="12" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel x:Name="LibraryMetricPanel" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="当前" Foreground="#8D8177" FontSize="12" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="VisibleBookCountText" Text="0 本" Foreground="#25211E" FontSize="13" FontWeight="Black"/>
                                            <TextBlock x:Name="TotalBookCountText" Text=" / 共 0 本" Foreground="#8D8177" FontSize="12" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="收藏" Foreground="#9A5A36" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="FavoriteCountText" Text="0 本" Foreground="#25211E" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="在读" Foreground="#447154" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="ReadingNowCountText" Text="0 本" Foreground="#25211E" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="读过" Foreground="#6B7280" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="ReadCountBookText" Text="0 本" Foreground="#25211E" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Button x:Name="LibraryChromeToggleButton" Content="专注浏览" Click="ToggleLibraryChrome_Click" Style="{StaticResource AppGhostButton}"/>
                            </StackPanel>
                        </Grid>
                        <WrapPanel x:Name="LibraryFilterControlsPanel" Grid.Row="1" VerticalAlignment="Center" ItemHeight="44">
                            <TextBox x:Name="BookSearchBox" Width="280" Height="44" Margin="0,0,10,0" TextChanged="BookSearchBox_TextChanged" Style="{StaticResource FilterTextBox}" ToolTip="搜索标题、作者、标签"/>
                            <ComboBox x:Name="AuthorFilterBox" Width="156" Height="44" Margin="0,0,10,0" ItemsSource="{Binding AuthorFilters}" SelectionChanged="BookFilter_Changed" Style="{StaticResource FilterComboBox}"/>
                            <ComboBox x:Name="StatusFilterBox" Width="148" Height="44" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="BookFilter_Changed" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="状态：全部"/>
                                <ComboBoxItem Content="状态：未读"/>
                                <ComboBoxItem Content="状态：在读"/>
                            </ComboBox>
                            <CheckBox x:Name="FavoriteOnlyBox" Content="只看收藏" Margin="0,0,10,0" Checked="BookFilter_Changed" Unchecked="BookFilter_Changed"/>
                            <ComboBox x:Name="SortBox" Width="174" Height="44" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="SortBox_SelectionChanged" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="排序：标题"/>
                                <ComboBoxItem Content="排序：进度"/>
                                <ComboBoxItem Content="排序：页数"/>
                                <ComboBoxItem Content="排序：容量"/>
                                <ComboBoxItem Content="排序：阅读次数"/>
                                <ComboBoxItem Content="排序：录入时间"/>
                                <ComboBoxItem Content="排序：出品时间"/>
                            </ComboBox>
                            <Button x:Name="BatchModeToggleButton" Content="多选管理" Click="ToggleBatchSelectionMode_Click" Style="{StaticResource FilterActionButton}" Height="44" Margin="0,0,10,0"/>
                            <Button Content="清空筛选" Click="ClearFilters_Click" Style="{StaticResource FilterActionButton}" Height="44"/>
                        </WrapPanel>
                        <Border x:Name="BatchManageShell" Grid.Row="2" Margin="0,10,0,0" Padding="8" CornerRadius="{StaticResource RadiusPanel}" Background="#EEF2F7" BorderBrush="#DDE4EE" BorderThickness="1" Visibility="Collapsed">
                            <WrapPanel x:Name="BatchManagePanel" VerticalAlignment="Center" ItemHeight="32">
                                <Border Padding="10,5" CornerRadius="{StaticResource RadiusControl}" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,6,0">
                                    <TextBlock x:Name="BatchSelectionText" Text="0 本" Foreground="#111827" FontSize="12" FontWeight="Black" VerticalAlignment="Center"/>
                                </Border>
                                <Button Content="全选" Click="SelectVisibleBooks_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="清空" Click="ClearBatchSelection_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="去前缀" Click="BatchRemoveTitlePrefix_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <ComboBox x:Name="BatchStyleBox" Width="96" Height="32" MinHeight="32" Padding="10,4" SelectedIndex="0" Style="{StaticResource FilterComboBox}" Margin="0,0,6,0">
                                    <ComboBoxItem Content="样式 1"/>
                                    <ComboBoxItem Content="样式 2"/>
                                    <ComboBoxItem Content="样式 3"/>
                                    <ComboBoxItem Content="样式 4"/>
                                </ComboBox>
                                <Button Content="应用" Click="BatchApplyStyle_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="+ Tag" Click="BatchAddTag_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="- Tag" Click="BatchRemoveTag_Click" Style="{StaticResource BatchActionButton}" Margin="0,0,6,0"/>
                                <Button Content="退出" Click="ExitBatchSelectionMode_Click" Style="{StaticResource BatchActionButton}"/>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="LibraryTagPanel" Grid.Row="1" Margin="8,0,22,16" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox x:Name="ShowHiddenBox" Content="显示隐藏作品" Margin="0,0,10,0" Checked="BookFilter_Changed" Unchecked="BookFilter_Changed"/>
                            </StackPanel>
                            <TextBlock x:Name="ActiveTagSummaryText" DockPanel.Dock="Right" Text="已选 0 个 Tag" VerticalAlignment="Center" Foreground="#8D8177"/>
                        </DockPanel>
                        <ItemsControl x:Name="ActiveTagFilterList" ItemsSource="{Binding ActiveTagFilters}" Visibility="Collapsed" Margin="0,0,0,12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TagChip}">
                                    <Border Style="{StaticResource AppTagChipBorder}"
                                            Margin="0,0,8,8"
                                            Padding="11,6"
                                            Background="{Binding Color}"
                                            BorderBrush="#111827"
                                            MouseLeftButtonDown="ActiveTagChip_Click">
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="编辑标签" Click="TagContextRename_Click"/>
                                                <MenuItem Header="删除标签" Click="TagContextDelete_Click"/>
                                                <Separator/>
                                                <MenuItem Header="前往标签页" Click="TagContextOpenManager_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/>
                                            <TextBlock Text=" ×" Foreground="#475569" FontSize="12" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" Content="添加" Click="AddTag_Click" Style="{StaticResource FilterActionButton}" Margin="8,0,0,0" Height="44"/>
                            <TextBox x:Name="TagSearchBox" TextChanged="TagSearchBox_TextChanged" Style="{StaticResource FilterTextBox}" Height="44" ToolTip="搜索 Tag；点添加可创建候选 Tag，选中漫画时会直接添加到漫画"/>
                        </DockPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="120" PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                            <ItemsControl x:Name="TagPool" ItemsSource="{Binding VisibleTags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TagChip}">
                                        <Border Margin="3"
                                                Padding="10,6"
                                                Background="{Binding Color}"
                                                MouseEnter="TagChip_MouseEnter"
                                                MouseLeave="TagChip_MouseLeave"
                                                PreviewMouseLeftButtonDown="TagChip_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="TagChip_PreviewMouseLeftButtonUp"
                                                MouseMove="TagChip_MouseMove"
                                                MouseLeftButtonDown="TagChip_MouseLeftButtonDown">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="编辑标签" Click="TagContextRename_Click"/>
                                                    <MenuItem Header="删除标签" Click="TagContextDelete_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="前往标签页" Click="TagContextOpenManager_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource AppTagChipBorder}">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Cursor" Value="Arrow"/>
                                                            <Setter Property="Opacity" Value="0.38"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Category}" FontSize="11" Margin="0,0,5,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource AppTagChipText}">
                                                            <Setter Property="Foreground" Value="#6B7280"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource AppTagChipText}">
                                                            <Setter Property="Foreground" Value="#25211E"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <ListBox x:Name="BooksList"
                             ItemsSource="{Binding Books}"
                             ItemContainerStyle="{StaticResource LibraryListItemStyle}"
                             ItemTemplate="{StaticResource LibraryBookTemplate}"
                             Margin="8,0,24,0"
                             SelectionChanged="BooksList_SelectionChanged"
                             MouseDoubleClick="BooksList_MouseDoubleClick"
                             AllowDrop="True"
                             DragEnter="LibraryPagePanel_DragEnter"
                             DragOver="LibraryPagePanel_DragOver"
                             DragLeave="LibraryPagePanel_DragLeave"
                             Drop="BooksList_Drop"
                             PreviewMouseWheel="FastItemsScrollViewer_PreviewMouseWheel"
                             Background="Transparent"
                             BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.CacheLength="4"
                             VirtualizingPanel.CacheLengthUnit="Page"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingWrapPanel ItemWidth="214"
                                                                ItemHeight="378"
                                                                HorizontalSpacing="18"
                                                                VerticalSpacing="14"
                                                                OverscanRows="2"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                    <Border x:Name="ShelfEmptyState" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="28" CornerRadius="{StaticResource RadiusPanel}" Background="#EFFFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1">
                        <StackPanel Width="320">
                            <TextBlock Text="当前漫画列表是空的" FontSize="26" FontWeight="Black" Foreground="#25211E" TextAlignment="Center"/>
                            <TextBlock x:Name="ShelfEmptyHintText" Text="可以先清空筛选，或者导入新的漫画文件夹。" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#6E645C" TextAlignment="Center" LineHeight="22"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="LibraryLoadProgressPanel"
                        Grid.RowSpan="4"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Margin="8,0,22,12"
                        CornerRadius="{StaticResource RadiusPanel}"
                        Background="#BDF8FAFC"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Panel.ZIndex="34">
                    <Border Width="520"
                            Padding="28"
                            CornerRadius="{StaticResource RadiusPanel}"
                            Background="#FFFFFF"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Effect="{StaticResource PanelShadow}">
                        <StackPanel>
                            <TextBlock x:Name="LibraryLoadProgressTitle"
                                       Text="正在加载漫画库"
                                       FontSize="26"
                                       FontWeight="Black"
                                       Foreground="#111827"
                                       TextAlignment="Center"/>
                            <ProgressBar x:Name="LibraryLoadProgressBar"
                                         Style="{StaticResource SlimProgressBar}"
                                         Margin="0,18,0,0"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="0"/>
                            <TextBlock x:Name="LibraryLoadProgressText"
                                       Text="准备扫描..."
                                       Margin="0,14,0,0"
                                       FontSize="13"
                                       Foreground="#475569"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>

                <Border x:Name="ImportProgressPanel"
                        Grid.RowSpan="4"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Margin="8,0,22,12"
                        CornerRadius="{StaticResource RadiusPanel}"
                        Background="#BDF8FAFC"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Panel.ZIndex="35">
                    <Border Width="520"
                            Padding="28"
                            CornerRadius="{StaticResource RadiusPanel}"
                            Background="#FFFFFF"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Effect="{StaticResource PanelShadow}">
                        <StackPanel>
                            <TextBlock x:Name="ImportProgressTitle"
                                       Text="正在导入"
                                       FontSize="26"
                                       FontWeight="Black"
                                       Foreground="#111827"
                                       TextAlignment="Center"/>
                            <ProgressBar x:Name="ImportProgressBar"
                                         Style="{StaticResource SlimProgressBar}"
                                         Margin="0,18,0,0"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="0"/>
                            <TextBlock x:Name="ImportProgressText"
                                       Text="准备中..."
                                       Margin="0,14,0,0"
                                       FontSize="13"
                                       Foreground="#475569"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>

                <Border x:Name="ImportDropOverlay"
                        Grid.RowSpan="4"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Margin="8,0,22,12"
                        CornerRadius="{StaticResource RadiusPanel}"
                        Background="#D9111827"
                        BorderBrush="#A7F3D0"
                        BorderThickness="2"
                        Panel.ZIndex="40">
                    <Grid>
                        <Border Width="520"
                                Padding="34"
                                CornerRadius="{StaticResource RadiusPanel}"
                                Background="#F8FFFC"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock x:Name="ImportDropTitle"
                                           Text="松开以导入漫画文件夹"
                                           FontSize="30"
                                           FontWeight="Black"
                                           Foreground="#111827"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="ImportDropHint"
                                           Text="会按作者文件夹识别子目录，并在导入前弹出确认列表。"
                                           Margin="0,12,0,0"
                                           FontSize="14"
                                           Foreground="#475569"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="TagsPagePanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="8,0,22,0">
                        <Border Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="标签管理" FontSize="30" FontWeight="Black" Foreground="#25211E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <Button Content="去书库" Click="NavLibrary_Click" Style="{StaticResource AppGhostButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                </StackPanel>

                <Grid Grid.Row="1" Margin="8,16,22,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="全部标签" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TagManagerTotalCountText" Text="0 个" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                                    <TextBlock Text="包含内置和用户标签" Margin="0,6,0,0" Foreground="#6E645C"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="正在使用" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TagManagerUsedCountText" Text="0 个" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                                    <TextBlock Text="至少关联 1 本漫画" Margin="0,6,0,0" Foreground="#6E645C"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource MetricCard}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="候选标签" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TagManagerStandaloneCountText" Text="0 个" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                                    <TextBlock Text="未关联时只能作为待分配标签" Margin="0,6,0,0" Foreground="#6E645C"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource MetricCard}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="标签组" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TagManagerGroupCountText" Text="0 组" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                                    <TextBlock Text="按分组统一颜色" Margin="0,6,0,0" Foreground="#6E645C"/>
                                </StackPanel>
                            </Border>
                </Grid>

                <Border Grid.Row="2" Margin="8,0,22,12" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" Content="新建候选标签" Click="CreateManagedTag_Click" Style="{StaticResource HeaderActionButton}" Margin="10,2,0,2"/>
                            <ComboBox x:Name="TagSortBox" DockPanel.Dock="Right" Width="130" Height="44" Margin="10,0,0,0" SelectedIndex="0" SelectionChanged="TagManagerFilter_Changed" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="按组排序"/>
                                <ComboBoxItem Content="按使用量"/>
                                <ComboBoxItem Content="按名称"/>
                            </ComboBox>
                            <ComboBox x:Name="TagGroupFilterBox" DockPanel.Dock="Right" Width="130" Height="44" Margin="10,0,0,0" SelectedIndex="0" SelectionChanged="TagManagerFilter_Changed" Style="{StaticResource FilterComboBox}">
                                <ComboBoxItem Content="全部分组"/>
                            </ComboBox>
                            <TextBox x:Name="TagManagerSearchBox" Height="44" TextChanged="TagManagerSearchBox_TextChanged" Style="{StaticResource FilterTextBox}" ToolTip="搜索标签"/>
                        </DockPanel>
                        <ListBox Grid.Row="1" x:Name="TagManagerList" ItemsSource="{Binding TagManagerItems}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 Focusable="False">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TagChip}">
                                    <Border Margin="0,0,0,10" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" HorizontalAlignment="Stretch">
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="编辑标签" Click="TagContextRename_Click"/>
                                                <MenuItem Header="删除标签" Click="TagContextDelete_Click"/>
                                                <Separator/>
                                                <MenuItem Header="按此标签筛选" Click="TagManagerFilter_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="按此标签筛选" Click="TagManagerFilter_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                                <Button Content="编辑标签" Click="RenameTagButton_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                                <Button Content="删除" Click="DeleteTagButton_Click" Style="{StaticResource AppDangerButton}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{Binding Color}" CornerRadius="{StaticResource RadiusControl}" Padding="10,5" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Category}" Foreground="#25211E" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="#25211E"/>
                                                </StackPanel>
                                                <WrapPanel Margin="0,8,0,0"
                                                           Cursor="Hand"
                                                           ToolTip="点击查看关联漫画"
                                                           MouseLeftButtonDown="TagUsage_MouseLeftButtonDown">
                                                    <TextBlock Text="已关联 " Foreground="#6B7280"/>
                                                    <TextBlock Text="{Binding UsageCount}" Foreground="#6B7280"/>
                                                    <TextBlock Text=" 本漫画" Foreground="#6B7280"/>
                                                    <TextBlock Text=" · " Foreground="#6B7280"/>
                                                    <TextBlock Text="{Binding SourceText}" Foreground="#6B7280"/>
                                                    <TextBlock Text=" · " Foreground="#6B7280"/>
                                                    <TextBlock Text="{Binding TypeText, Mode=OneWay}" Foreground="#6B7280"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2" x:Name="TagManagerEmptyState" Visibility="Collapsed" Margin="0,4,0,0" Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="#F8FAFC">
                            <TextBlock Text="当前没有命中的标签，可以换个关键词，或者新建一个新的标签。"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="AuthorsPagePanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="8,0,22,0">
                        <Border Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="作者管理" FontSize="30" FontWeight="Black" Foreground="#25211E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <Button Content="新增作者" Click="CreateAuthor_Click" Style="{StaticResource HeaderActionButton}" Margin="0,0,10,0"/>
                                    <Button Content="去书库" Click="NavLibrary_Click" Style="{StaticResource AppGhostButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                </StackPanel>

                <Grid Grid.Row="1" Margin="8,16,22,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="全部作者" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AuthorTotalText" Text="0 位" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                            <TextBlock Text="去重计数" Margin="0,6,0,0" Foreground="#6E645C"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource MetricCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="关联书籍" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AuthorBookTotalText" Text="0 本" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                            <TextBlock Text="已指定作者的漫画" Margin="0,6,0,0" Foreground="#6E645C"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Margin="8,0,22,12" Padding="16" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="AuthorSearchBox" Height="44" Margin="0,0,0,12" TextChanged="AuthorSearchBox_TextChanged" Style="{StaticResource FilterTextBox}" ToolTip="搜索作者名"/>
                        <ListBox Grid.Row="1" x:Name="AuthorManagerList" ItemsSource="{Binding AuthorManagerItems}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 Focusable="False">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:AuthorItem}">
                                    <Border Margin="0,0,0,6" Padding="14,10" CornerRadius="{StaticResource RadiusPanel}" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" HorizontalAlignment="Stretch">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="按照此作者筛选" Click="FilterByAuthor_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                                <Button Content="修改作者信息" Click="RenameAuthor_Click" Style="{StaticResource AppGhostButton}" Margin="0,0,8,0"/>
                                                <Button Content="删除" Click="DeleteAuthor_Click" Style="{StaticResource AppDangerButton}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="#25211E"/>
                                                <TextBlock Text="{Binding BookCount, StringFormat={}{0} 本书籍}" FontSize="12" Foreground="#6B7280"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2" x:Name="AuthorManagerEmptyState" Visibility="Collapsed" Margin="0,4,0,0" Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="#F8FAFC">
                            <TextBlock Text="没有匹配的作者。"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="LogPanel"
                    Grid.Row="1"
                    Height="160"
                    Margin="8,14,22,0"
                    Padding="0"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="#111827"
                    BorderBrush="#263244"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="输出"
                                   VerticalAlignment="Center"
                                   Foreground="#F8FAFC"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Column="1"
                                   Text="实时状态 / app 日志"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="12"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="LogPanelExpandButton" Content="扩大" Click="ToggleLogPanelSize_Click" Style="{StaticResource TinyButton}" Margin="0,0,10,0"/>
                            <Button Content="清空" Click="ClearLogOutput_Click" Style="{StaticResource TinyButton}" Margin="0,0,10,0"/>
                            <Button Content="打开日志目录" Click="OpenLogFolder_Click" Style="{StaticResource TinyButton}"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Margin="12,0" CornerRadius="{StaticResource RadiusControl}" Background="#0B1220">
                        <ScrollViewer x:Name="LogOutputScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Padding="14,12">
                            <TextBlock x:Name="LogOutputText"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#CBD5E1"
                                       TextWrapping="NoWrap"/>
                        </ScrollViewer>
                    </Border>
                    <TextBlock x:Name="StatusText"
                               Grid.Row="2"
                               Margin="16,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="#D6A05F"
                               FontSize="12"/>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="DetailDismissOverlay"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Panel.ZIndex="9"
                Visibility="Collapsed"
                Background="#01000000"
                MouseDown="DetailDismissOverlay_MouseDown"/>

        <Border x:Name="DetailShell"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Width="1080"
                MaxHeight="820"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="10"
                Visibility="Collapsed"
                Margin="26"
                Padding="20"
                CornerRadius="{StaticResource RadiusPanel}"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="1"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="DetailBackButton"
                            Grid.Column="0"
                            Content="← 返回书库"
                            Click="ReturnToLibrary_Click"
                            Style="{StaticResource DetailTopBarButton}"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="ToggleFavoriteButton"
                                Content="☆ 收藏"
                                Click="ToggleFavorite_Click"
                                Style="{StaticResource DetailTopBarFavoriteButton}"
                                Margin="0,0,8,0"/>
                        <Button x:Name="EditModeButton"
                                Content="编辑"
                                Click="ToggleEditMode_Click"
                                Style="{StaticResource DetailTopBarButton}"
                                Margin="0,0,8,0"/>
                        <Button x:Name="MoreActionsButton"
                                Content="更多 ▾"
                                Click="OpenMoreActionsMenu_Click"
                                Style="{StaticResource DetailTopBarButton}">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="MoreActionsMenu">
                                    <MenuItem Header="打开所在文件夹" Click="OpenFolder_Click"/>
                                    <MenuItem Header="重新定位" Click="Relocate_Click"/>
                                    <MenuItem Header="切换卡片样式" Click="CycleBookStyle_Click"/>
                                    <MenuItem x:Name="MoreActionsHideMenuItem" Header="隐藏作品" Click="HideBook_Click"/>
                                    <Separator/>
                                    <MenuItem Header="删除库记录" Click="DeleteBook_Click" Foreground="#B91C1C"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                    <Grid>
                        <StackPanel x:Name="EmptyDetailPanel" Visibility="Collapsed" VerticalAlignment="Center" Margin="0,80,0,0">
                            <Border Width="96" Height="132" CornerRadius="{StaticResource RadiusPanel}" Background="{StaticResource Brush.SurfaceMuted}" HorizontalAlignment="Center" Effect="{StaticResource BookShadow}"/>
                            <TextBlock Text="选择一本书" FontSize="24" FontWeight="Black" Margin="0,24,0,0" HorizontalAlignment="Center" Foreground="{StaticResource Brush.TextPrimary}"/>
                            <TextBlock Text="书籍信息、标签和简介会在这里以卡片方式编辑。" Margin="24,8" Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>

                        <DockPanel x:Name="DetailPanel" Visibility="Collapsed" LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left" Width="320" Margin="0,0,40,0">
                                <Border Width="320"
                                        Height="480"
                                        CornerRadius="{StaticResource RadiusPanel}"
                                        Background="{StaticResource Brush.SurfaceMuted}"
                                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                                        BorderThickness="1"
                                        ClipToBounds="True"
                                        Effect="{StaticResource BookShadow}">
                                    <Image Source="{Binding CoverImage}" Stretch="Uniform"/>
                                </Border>
                                <TextBlock x:Name="DetailCoverPageText"
                                           Style="{StaticResource DetailCoverPageHintText}"/>
                                <Button x:Name="DetailOpenCatalogButton"
                                        Content="打开目录"
                                        Click="DetailOpenCatalog_Click"
                                        Style="{StaticResource DetailHeroSecondaryButton}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,12,0,0"/>
                            </StackPanel>

                            <StackPanel>
                                <StackPanel x:Name="ReadOnlyInfoPanel">
                                    <TextBlock x:Name="BookTitleText"
                                               Style="{StaticResource DetailHeroTitleText}"/>
                                    <WrapPanel Margin="0,8,0,0" VerticalAlignment="Center">
                                        <Button x:Name="BookAuthorFilterButton"
                                                Click="DetailAuthorFilter_Click"
                                                Style="{StaticResource DetailHeroSecondaryButton}"
                                                Margin="0,0,8,8"/>
                                        <Border Padding="14,7"
                                                Margin="0,0,8,8"
                                                CornerRadius="{StaticResource RadiusControl}"
                                                Background="{StaticResource Brush.SurfaceMuted}"
                                                BorderBrush="{StaticResource Brush.BorderSubtle}"
                                                BorderThickness="1">
                                            <TextBlock x:Name="BookMetaLineText"
                                                       Style="{StaticResource DetailHeroMetaText}"
                                                       Margin="0"/>
                                        </Border>
                                        <ItemsControl x:Name="BookTagChips" Margin="0,0,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:TagChip}">
                                                    <Border Style="{StaticResource AppTagChipBorder}"
                                                            Background="{Binding Color}"
                                                            MouseEnter="TagChip_MouseEnter"
                                                            MouseLeave="TagChip_MouseLeave"
                                                            PreviewMouseLeftButtonDown="TagChip_PreviewMouseLeftButtonDown"
                                                            PreviewMouseLeftButtonUp="TagChip_PreviewMouseLeftButtonUp"
                                                            MouseLeftButtonDown="TagChip_MouseLeftButtonDown">
                                                        <TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </WrapPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                        <Button Content="开始阅读"
                                                Click="OpenCurrentBook_Click"
                                                Style="{StaticResource DetailHeroPrimaryButton}"
                                                Margin="0,0,12,0"/>
                                        <Button Content="-1"
                                                Click="DecreaseReadCount_Click"
                                                Style="{StaticResource DetailHeroSecondaryButton}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="+1"
                                                Click="IncreaseReadCount_Click"
                                                Style="{StaticResource DetailHeroSecondaryButton}"
                                                Margin="0,0,12,0"/>
                                        <Button Content="打开所在文件夹"
                                                Click="OpenFolder_Click"
                                                Style="{StaticResource DetailHeroSecondaryButton}"
                                                Margin="0,0,10,0"/>
                                        <Button Content="重新定位"
                                                Click="Relocate_Click"
                                                Style="{StaticResource DetailHeroSecondaryButton}"/>
                                    </StackPanel>

                                    <TextBlock x:Name="ReadingStatusInlineText"
                                               Style="{StaticResource DetailReadingStatusText}"/>

                                    <!-- 隐藏的旧字段控件，供代码后置继续赋值，避免空引用 -->
                                    <StackPanel Visibility="Collapsed">
                                        <TextBlock x:Name="ReadOnlyAuthorText"/>
                                        <TextBlock x:Name="ReadOnlyForeignNameText"/>
                                        <TextBlock x:Name="ReadOnlyPageCountText"/>
                                        <TextBlock x:Name="ReadOnlyCoverPageText"/>
                                        <TextBlock x:Name="ReadOnlyStatusText"/>
                                        <TextBlock x:Name="ReadOnlyReadCountText"/>
                                        <TextBlock x:Name="ReadOnlyProducedAtText"/>
                                        <TextBlock x:Name="ReadOnlyImportedAtText"/>
                                        <TextBlock x:Name="ReadOnlyTagsText"/>
                                        <Button x:Name="HideBookButton" Click="HideBook_Click"/>
                                    </StackPanel>

                                    <Border Margin="0,28,0,0" Padding="0" Background="Transparent">
                                        <StackPanel>
                                            <TextBlock Text="简介" Style="{StaticResource DetailSectionTitleText}"/>
                                            <TextBlock x:Name="ReadOnlySummaryText"
                                                       Style="{StaticResource DetailSummaryText}"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,28,0,0">
                                        <TextBlock Text="作品信息" Style="{StaticResource DetailSectionTitleText}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="作者" Style="{StaticResource DetailMetaLabelText}" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="MetaAuthorValueText" Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailMetaValueText}" Margin="0,0,0,10"/>
                                            <TextBlock Grid.Row="0" Grid.Column="3" Text="外文名" Style="{StaticResource DetailMetaLabelText}" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="MetaForeignNameValueText" Grid.Row="0" Grid.Column="4" Style="{StaticResource DetailMetaValueText}" Margin="0,0,0,10"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="页数" Style="{StaticResource DetailMetaLabelText}" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="MetaPageCountValueText" Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailMetaValueText}" Margin="0,0,0,10"/>
                                            <TextBlock Grid.Row="1" Grid.Column="3" Text="封面页" Style="{StaticResource DetailMetaLabelText}" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="MetaCoverPageValueText" Grid.Row="1" Grid.Column="4" Style="{StaticResource DetailMetaValueText}" Margin="0,0,0,10"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="出品时间" Style="{StaticResource DetailMetaLabelText}"/>
                                            <TextBlock x:Name="MetaProducedAtValueText" Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailMetaValueText}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="3" Text="录入时间" Style="{StaticResource DetailMetaLabelText}"/>
                                            <TextBlock x:Name="MetaImportedAtValueText" Grid.Row="2" Grid.Column="4" Style="{StaticResource DetailMetaValueText}"/>
                                        </Grid>
                                    </StackPanel>

                                </StackPanel>

                                <StackPanel x:Name="EditFormPanel" Visibility="Collapsed">
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="编辑作品信息" Style="{StaticResource DetailEditFormHeaderText}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="取消"
                                                    Click="ToggleEditMode_Click"
                                                    Style="{StaticResource DetailHeroSecondaryButton}"
                                                    Margin="0,0,10,0"/>
                                            <Button x:Name="SaveMetadataButton"
                                                    Content="保存信息"
                                                    Click="SaveMetadata_Click"
                                                    Style="{StaticResource DetailHeroPrimaryButton}"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel>
                                        <TextBlock Text="书名" Style="{StaticResource LabelText}"/>
                                        <TextBox x:Name="TitleBox" Margin="0,0,0,14"/>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="作者" Style="{StaticResource LabelText}"/>
                                                <TextBox x:Name="AuthorBox"
                                                         TextChanged="EditAuthorSearchBox_TextChanged"
                                                         ToolTip="只能选择作者管理中已有作者"/>
                                                <ItemsControl ItemsSource="{Binding EditAuthorOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              Margin="0,8,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type models:AuthorItem}">
                                                            <Border Style="{StaticResource AppTagChipBorder}"
                                                                    Background="#E5E7EB"
                                                                    MouseLeftButtonDown="EditAuthorOption_Click"
                                                                    ToolTip="点击选择作者">
                                                                <TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="外文名" Style="{StaticResource LabelText}"/>
                                                <TextBox x:Name="ForeignNameBox"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="阅读状态" Style="{StaticResource LabelText}"/>
                                                <ComboBox x:Name="ReadingStatusBox" SelectedIndex="0">
                                                    <ComboBoxItem Content="未读" Tag="unread"/>
                                                    <ComboBoxItem Content="在读" Tag="reading"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="阅读次数" Style="{StaticResource LabelText}"/>
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                                        <Button Content="-1" Click="DecreaseReadCount_Click" Style="{StaticResource TinyButton}" Margin="0,0,8,0"/>
                                                        <Button Content="+1" Click="IncreaseReadCount_Click" Style="{StaticResource TinyButton}"/>
                                                    </StackPanel>
                                                    <TextBox x:Name="ReadCountBox"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="出品时间" Style="{StaticResource LabelText}"/>
                                                <TextBox x:Name="ProducedAtBox"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="录入时间" Style="{StaticResource LabelText}"/>
                                                <DockPanel>
                                                    <Button x:Name="ImportedTodayButton" DockPanel.Dock="Right" Content="今日" Click="ImportedToday_Click" Style="{StaticResource TinyButton}" Margin="8,0,0,0"/>
                                                    <TextBox x:Name="ImportedAtBox"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.7*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="Tag" Style="{StaticResource LabelText}"/>
                                                </DockPanel>
                                                <TextBox x:Name="EditTagSearchBox"
                                                         Margin="0,0,0,8"
                                                         TextChanged="EditTagSearchBox_TextChanged"
                                                         ToolTip="输入关键词搜索已有 Tag"/>
                                                <TextBox x:Name="TagsBox" Visibility="Collapsed"/>
                                                <Border MinHeight="76"
                                                        MaxHeight="132"
                                                        Padding="10"
                                                        CornerRadius="{StaticResource RadiusField}"
                                                        Background="{StaticResource Brush.Surface}"
                                                        BorderBrush="{StaticResource Brush.BorderStrong}"
                                                        BorderThickness="1">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                                                        <StackPanel>
                                                            <ItemsControl ItemsSource="{Binding EditSelectedTagItems, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type models:TagChip}">
                                                                        <Border Style="{StaticResource AppTagChipBorder}"
                                                                                Background="{Binding Color}"
                                                                                MouseLeftButtonDown="EditTagRemove_Click"
                                                                                ToolTip="点击移除">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/>
                                                                                <TextBlock Text=" ×" FontSize="12" FontWeight="Bold" Foreground="#475569"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Separator Margin="0,2,0,8"/>
                                                            <ItemsControl ItemsSource="{Binding EditTagOptions, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type models:TagChip}">
                                                                        <Border Style="{StaticResource AppTagChipBorder}"
                                                                                Background="{Binding Color}"
                                                                                Opacity="0.72"
                                                                                MouseLeftButtonDown="EditTagOption_Click"
                                                                                ToolTip="点击添加">
                                                                            <TextBlock Text="{Binding Name}" Style="{StaticResource AppTagChipText}"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="封面页" Style="{StaticResource LabelText}"/>
                                                <TextBox x:Name="CoverPageBox"/>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="简介" Style="{StaticResource LabelText}"/>
                                        <TextBox x:Name="SummaryBox"
                                                 Height="92"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,28,0,0">
                                        <TextBlock Text="危险操作" Style="{StaticResource DetailSectionTitleText}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="HideBookButtonEdit"
                                                    Content="隐藏作品"
                                                    Click="HideBook_Click"
                                                    Style="{StaticResource DetailFileActionButton}"/>
                                            <Button Content="删除库记录"
                                                    Click="DeleteBook_Click"
                                                    Style="{StaticResource DetailDangerInlineButton}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBox x:Name="NextShortcutBox" Text="Right,Space"/>
                                            <TextBox x:Name="PrevShortcutBox" Text="Left"/>
                                            <Button Content="保存快捷键" Click="SaveShortcuts_Click"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="EditModeHintText" Visibility="Collapsed"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid x:Name="DetailCatalogOverlay"
              Grid.Column="1"
              Grid.ColumnSpan="2"
              Panel.ZIndex="18"
              Visibility="Collapsed"
              Background="#99000000"
              PreviewMouseWheel="DetailCatalogOverlay_PreviewMouseWheel">
            <Border Width="980"
                    MaxHeight="760"
                    Margin="26"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="{StaticResource RadiusPanel}"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    Effect="{StaticResource PanelShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="DetailCatalogTitleText"
                                       Text="目录"
                                       FontSize="24"
                                       FontWeight="Black"
                                       Foreground="{StaticResource Brush.TextPrimary}"/>
                            <TextBlock Text="左键预览页面；右键可将图片设为封面。不会启动阅读器。"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextMuted}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="关闭"
                                Click="CloseDetailCatalog_Click"
                                Style="{StaticResource DetailHeroSecondaryButton}"
                                VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="310"/>
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="DetailCatalogList"
                                 ItemsSource="{Binding DetailPageCatalogItems}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PageCatalogItem}">
                                    <Border Width="118"
                                            Height="176"
                                            Margin="6"
                                            Padding="7"
                                            CornerRadius="{StaticResource RadiusControl}"
                                            Background="{StaticResource Brush.SurfaceMuted}"
                                            BorderBrush="{StaticResource Brush.BorderSubtle}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="DetailCatalogItem_MouseLeftButtonDown">
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="设为封面" Click="SetDetailCatalogPageAsCover_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border CornerRadius="{StaticResource RadiusControl}"
                                                    Background="#111827"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="LowQuality"/>
                                            </Border>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding PageText}"
                                                       Margin="0,7,0,0"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource Brush.TextMuted}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Column="1"
                                Margin="18,0,0,0"
                                Padding="14"
                                CornerRadius="{StaticResource RadiusPanel}"
                                Background="{StaticResource Brush.SurfaceMuted}"
                                BorderBrush="{StaticResource Brush.BorderSubtle}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border CornerRadius="{StaticResource RadiusControl}"
                                        Background="#111827"
                                        ClipToBounds="True">
                                    <Image x:Name="DetailCatalogPreviewImage"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock x:Name="DetailCatalogPreviewText"
                                           Grid.Row="1"
                                           Text="选择一页预览"
                                           Margin="0,12,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
