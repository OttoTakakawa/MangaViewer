                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="编辑标签" Click="TagContextRename_Click"/>
                                                <MenuItem Header="删除标签" Click="TagContextDelete_Click"/>
                                                <Separator/>
                                                <MenuItem Header="前往标签页" Click="TagContextOpenManager_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Foreground="#25211E" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text=" ×" Foreground="#475569" FontSize="12" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" Content="添加" Click="AddTag_Click" Style="{StaticResource FilterPillButton}" Margin="8,0,0,0" Height="44"/>
                            <TextBox x:Name="TagSearchBox" TextChanged="TagSearchBox_TextChanged" Style="{StaticResource FilterPillTextBox}" Height="44" ToolTip="搜索 Tag；点添加可创建候选 Tag，选中漫画时会直接添加到漫画"/>
                        </DockPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="120" PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
