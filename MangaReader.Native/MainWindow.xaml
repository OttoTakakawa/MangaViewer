                    <StackPanel x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="书籍详情" FontSize="28" FontWeight="Black" Foreground="#25211E" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="ToggleFavoriteButton" Content="收藏" Click="ToggleFavorite_Click" Style="{StaticResource TinyButton}" Margin="0,0,8,0"/>
                                <Button x:Name="EditModeButton" Content="编辑" Click="ToggleEditMode_Click" Style="{StaticResource TinyButton}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="EditModeHintText" Text="只读模式：点击“编辑”后修改信息" Margin="0,0,0,20" Foreground="#81756B"/>
                        <StackPanel x:Name="ReadOnlyInfoPanel">
                            <TextBlock Text="作者" Style="{StaticResource LabelText}"/>
                            <TextBlock x:Name="ReadOnlyAuthorText" FontSize="18" FontWeight="Bold" Foreground="#25211E" Margin="0,0,0,18" TextWrapping="Wrap"/>
                            <TextBlock Text="外文名" Style="{StaticResource LabelText}"/>
                            <TextBlock x:Name="ReadOnlyForeignNameText" FontSize="18" FontWeight="Bold" Foreground="#25211E" Margin="0,0,0,18" TextWrapping="Wrap"/>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="阅读状态" Style="{StaticResource LabelText}"/>
                                    <TextBlock x:Name="ReadOnlyStatusText" FontSize="16" FontWeight="Bold" Foreground="#25211E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="收藏" Style="{StaticResource LabelText}"/>
                                    <TextBlock x:Name="ReadOnlyFavoriteText" FontSize="16" FontWeight="Bold" Foreground="#25211E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="页数" Style="{StaticResource LabelText}"/>
                                    <TextBlock x:Name="ReadOnlyPageCountText" FontSize="16" FontWeight="Bold" Foreground="#25211E"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="出品时间" Style="{StaticResource LabelText}"/>
                                    <TextBlock x:Name="ReadOnlyProducedAtText" FontSize="16" Foreground="#25211E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="录入时间" Style="{StaticResource LabelText}"/>
                                    <TextBlock x:Name="ReadOnlyImportedAtText" FontSize="16" Foreground="#25211E"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Tag" Style="{StaticResource LabelText}"/>
                            <TextBlock x:Name="ReadOnlyTagsText" FontSize="16" Foreground="#25211E" Margin="0,0,0,18" TextWrapping="Wrap"/>
                            <TextBlock Text="封面页" Style="{StaticResource LabelText}"/>
                            <TextBlock x:Name="ReadOnlyCoverPageText" FontSize="16" Foreground="#25211E" Margin="0,0,0,18"/>
                            <TextBlock Text="阅读次数" Style="{StaticResource LabelText}"/>
                            <Border Padding="14" CornerRadius="9" Background="#F8F2EC" Margin="0,0,0,18">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                                        <Button Content="-1" Click="DecreaseReadCount_Click" Style="{StaticResource TinyButton}" Margin="0,0,8,0"/>
                                        <Button Content="+1" Click="IncreaseReadCount_Click" Style="{StaticResource TinyButton}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ReadOnlyReadCountText" FontSize="16" FontWeight="Bold" Foreground="#25211E" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <TextBlock Text="简介" Style="{StaticResource LabelText}"/>
                            <Border Padding="14" CornerRadius="9" Background="#F8F2EC" Margin="0,0,0,18">
                                <TextBlock x:Name="ReadOnlySummaryText" TextWrapping="Wrap" Foreground="#25211E" LineHeight="22"/>
                            </Border>
                            <Button Content="开始阅读" Click="OpenCurrentBook_Click" Margin="0,0,0,10"/>
                            <Button Content="打开所在文件夹" Click="OpenFolder_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                            <Button Content="切换卡片样式" Click="CycleBookStyle_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                            <Button x:Name="HideBookButton" Content="隐藏作品" Click="HideBook_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                            <Button Content="重新定位" Click="Relocate_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                        </StackPanel>
                        <StackPanel x:Name="EditFormPanel" Visibility="Collapsed">
                        <TextBlock Text="书名" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="TitleBox" Margin="0,0,0,12"/>
                        <TextBlock Text="作者" Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="AuthorBox" Margin="0,0,0,12" Foreground="#666" MinHeight="36" VerticalAlignment="Center" Padding="8,8,0,0"/>
                        <TextBlock Text="外文名" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="ForeignNameBox" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="阅读状态" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="ReadingStatusBox" SelectedIndex="0">
                                    <ComboBoxItem Content="未读" Tag="unread"/>
                                    <ComboBoxItem Content="在读" Tag="reading"/>
                                    <ComboBoxItem Content="已读" Tag="finished"/>
                                    <ComboBoxItem Content="搁置" Tag="paused"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="收藏" Style="{StaticResource LabelText}"/>
                                <CheckBox x:Name="FavoriteBox" Content="收藏这本漫画" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="出品时间" Style="{StaticResource LabelText}"/>
                                <TextBox x:Name="ProducedAtBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="录入时间" Style="{StaticResource LabelText}"/>
                                <DockPanel>
                                    <Button x:Name="ImportedTodayButton" DockPanel.Dock="Right" Content="今日" Click="ImportedToday_Click" Style="{StaticResource GhostButton}" Margin="8,0,0,0"/>
                                    <TextBox x:Name="ImportedAtBox"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Tag（逗号分隔）" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="TagsBox" Margin="0,0,0,12"/>
                        <TextBlock Text="封面页" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="CoverPageBox" Margin="0,0,0,12"/>
                        <TextBlock Text="阅读次数" Style="{StaticResource LabelText}"/>
                        <DockPanel Margin="0,0,0,12">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Content="-1" Click="DecreaseReadCount_Click" Style="{StaticResource TinyButton}" Margin="0,0,8,0"/>
                                <Button Content="+1" Click="IncreaseReadCount_Click" Style="{StaticResource TinyButton}"/>
                            </StackPanel>
                            <TextBox x:Name="ReadCountBox"/>
                        </DockPanel>
                        <TextBlock Text="简介" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="SummaryBox" Height="128" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,18"/>
                        <Button x:Name="SaveMetadataButton" Content="保存信息" Click="SaveMetadata_Click" Margin="0,0,0,10"/>
                        <Button Content="开始阅读" Click="OpenCurrentBook_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                        <Button x:Name="SetCoverButton" Content="设置为封面页" Click="SetCover_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                        <Button Content="切换卡片样式" Click="CycleBookStyle_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                        <Button Content="打开所在文件夹" Click="OpenFolder_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                        <Button x:Name="HideBookButtonEdit" Content="隐藏作品" Click="HideBook_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                        <Button Content="重新定位" Click="Relocate_Click" Style="{StaticResource GhostButton}" Margin="0,0,0,10"/>
                        <Button Content="删除库记录" Click="DeleteBook_Click" Style="{StaticResource DangerButton}"/>
                        </StackPanel>

                        <Border Visibility="Collapsed" Margin="0,22,0,0" Padding="16" CornerRadius="11" Background="#F6EFE7">
                            <StackPanel>
                                <TextBlock Text="阅读快捷键" FontWeight="Black" Foreground="#25211E"/>
                                <TextBlock Text="下一页" Style="{StaticResource LabelText}" Margin="0,12,0,6"/>
                                <TextBox x:Name="NextShortcutBox" Text="Right,Space"/>
                                <TextBlock Text="上一页" Style="{StaticResource LabelText}" Margin="0,12,0,6"/>
                                <TextBox x:Name="PrevShortcutBox" Text="Left"/>
                                <Button Content="保存快捷键" Click="SaveShortcuts_Click" Style="{StaticResource TinyButton}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
        <Button x:Name="DetailDrawerToggleButton"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Width="36"
                Height="76"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Panel.ZIndex="11"
                Visibility="Collapsed"
                Content="‹"
                Click="ToggleDetailDrawer_Click"
                Style="{StaticResource TinyButton}"
                Margin="0,0,26,0"/>
    </Grid>
</Window>
