<Window x:Class="MangaReader.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:MangaReader.Native.Controls"
        xmlns:models="clr-namespace:MangaReader.Native.Models"
        mc:Ignorable="d"
        Title="漫画库" Height="900" Width="1500" MinHeight="760" MinWidth="1180"
        Background="#F6F7F9" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <CornerRadius x:Key="RadiusClip">4</CornerRadius>
        <CornerRadius x:Key="RadiusProgress">5</CornerRadius>
        <CornerRadius x:Key="RadiusControl">9</CornerRadius>
        <CornerRadius x:Key="RadiusPanel">10</CornerRadius>
        <CornerRadius x:Key="RadiusField">11</CornerRadius>
        <CornerRadius x:Key="RadiusTag">16</CornerRadius>
        <CornerRadius x:Key="RadiusDialog">32</CornerRadius>
        <CornerRadius x:Key="RadiusPill">999</CornerRadius>
        <DropShadowEffect x:Key="BookShadow" Color="#111827" BlurRadius="18" ShadowDepth="6" Opacity="0.14"/>
        <DropShadowEffect x:Key="PanelShadow" Color="#111827" BlurRadius="28" ShadowDepth="10" Opacity="0.08"/>

        <Style TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusControl}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFF1F2"/>
            <Setter Property="BorderBrush" Value="#FECDD3"/>
            <Setter Property="Foreground" Value="#9F1239"/>
        </Style>
        <Style x:Key="FilterPillButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusField}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TinyButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="BatchPillButton" TargetType="Button" BasedOn="{StaticResource TinyButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style x:Key="PillProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusProgress}"/>
                            <Border x:Name="PART_Track" CornerRadius="{StaticResource RadiusProgress}"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource RadiusProgress}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterPillTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusField}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9CA3AF"/>
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="BorderBrush" Value="#D8DEE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource RadiusField}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="BorderBrush" Value="#D8DEE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" SnapsToDevicePixels="True">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusField}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="16,0,4,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Grid Grid.Column="1">
                                        <Path Data="M 0 0 L 4 4 L 8 0"
                                              Stroke="#6B7280"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=ComboRoot}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,6,0,0"
                                        Width="{Binding ActualWidth, ElementName=ComboRoot}"
                                        Background="#FFFFFF"
                                        BorderBrush="#D8DEE8"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusField}"
                                        Effect="{StaticResource PanelShadow}">
                                    <ScrollViewer MaxHeight="280"
                                                  CanContentScroll="True">
                                        <ItemsPresenter Margin="4"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#C4CCD7"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterPillComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="FilterComboBox_PreviewMouseLeftButtonDown"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" SnapsToDevicePixels="True">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusField}">
                                <Grid Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Border Grid.Column="1"
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,10,0"
                                            Background="#EEF2F7"
                                            CornerRadius="{StaticResource RadiusPill}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                        <Path Data="M 0 0 L 5 5 L 10 0"
                                              Stroke="#6B7280"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=ComboRoot}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,8,0,0"
                                        Width="{Binding ActualWidth, ElementName=ComboRoot}"
                                        Background="#FFFFFF"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusControl}"
                                        Effect="{StaticResource PanelShadow}">
                                    <ScrollViewer MaxHeight="280" CanContentScroll="True">
                                        <ItemsPresenter Margin="6"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#9CA3AF"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusPanel}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#E5E7EB"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemRoot" Property="Background" Value="#DDE3EA"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="PillRoot"
                                MinHeight="36"
                                Padding="12,7"
                                Background="#F8FAFC"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusControl}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="CheckMark"
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,8,0"
                                        Background="#FFFFFF"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusPill}">
                                    <Path x:Name="CheckGlyph"
                                          Data="M 4 9 L 7 12 L 14 5"
                                          Stroke="#FFFFFF"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillRoot" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="PillRoot" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PillRoot" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="PillRoot" Property="BorderBrush" Value="#C7D2FE"/>
                                <Setter TargetName="CheckMark" Property="Background" Value="#111827"/>
                                <Setter TargetName="CheckMark" Property="BorderBrush" Value="#111827"/>
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BatchSelectCheckBox" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="SelectRoot"
                                Width="30"
                                Height="30"
                                Background="#DDF8FAFC"
                                BorderBrush="#94A3B8"
                                BorderThickness="1.2"
                                CornerRadius="15">
                            <Grid>
                                <Ellipse x:Name="SelectDot"
                                         Width="16"
                                         Height="16"
                                         Fill="Transparent"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                                <Path x:Name="SelectGlyph"
                                      Data="M 5 10 L 8 13 L 15 6"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectRoot" Property="Background" Value="#EEF2F7"/>
                                <Setter TargetName="SelectRoot" Property="BorderBrush" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SelectRoot" Property="Background" Value="#111827"/>
                                <Setter TargetName="SelectRoot" Property="BorderBrush" Value="#111827"/>
                                <Setter TargetName="SelectDot" Property="Fill" Value="#111827"/>
                                <Setter TargetName="SelectGlyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="SidebarNavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
        <Style x:Key="SidebarActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="LibraryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="214"/>
            <Setter Property="Height" Value="378"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SelectionFrame" Padding="4" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" CornerRadius="28">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectionFrame" Property="Background" Value="#0D111827"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionFrame" Property="Background" Value="#18111827"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SelectionFrame" Property="Background" Value="#24111827"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="LibraryBookTemplate">
            <Border x:Name="LibraryBookCard"
                    Width="198"
                    Height="360"
                    Padding="12"
                    CornerRadius="12"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    MouseEnter="BookCard_MouseEnter"
                    MouseLeave="BookCard_MouseLeave"
                    PreviewMouseLeftButtonDown="BookCard_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="BookCard_PreviewMouseLeftButtonUp"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <StackPanel>
                    <Grid Width="162" Height="220" HorizontalAlignment="Center">
                        <Grid Width="150" Height="214" VerticalAlignment="Top" Effect="{StaticResource BookShadow}">
                            <Grid x:Name="GrooveCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border CornerRadius="5" ClipToBounds="True" Background="Transparent">
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>
                                <Rectangle Width="3" Margin="34,12,0,12" HorizontalAlignment="Left" Fill="#66000000" RadiusX="1.5" RadiusY="1.5"/>
                                <Rectangle Width="1" Margin="39,14,0,14" HorizontalAlignment="Left" Fill="#66FFFFFF" RadiusX="1" RadiusY="1"/>
                            </Grid>

                            <Grid x:Name="BoundMangaCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="1">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border CornerRadius="4" ClipToBounds="True" Background="Transparent">
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>
                                <Border Width="42" HorizontalAlignment="Left" CornerRadius="4,0,0,4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#70000000" Offset="0"/>
                                            <GradientStop Color="#26000000" Offset="0.48"/>
                                            <GradientStop Color="#24FFFFFF" Offset="0.66"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Rectangle Width="12" HorizontalAlignment="Left" Margin="27,5,0,5" RadiusX="6" RadiusY="6" Opacity="0.38">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00000000" Offset="0"/>
                                            <GradientStop Color="#55FFFFFF" Offset="0.55"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>

                            <Grid x:Name="PlainCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="2">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border CornerRadius="3" ClipToBounds="True" Background="Transparent">
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                </Border>
                            </Grid>

                            <Grid x:Name="WhiteBorderCover">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BookStyleIndex}" Value="3">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border Background="#FAFFFFFF" CornerRadius="6" Padding="7">
                                    <Border CornerRadius="2" ClipToBounds="True" Background="Transparent">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>
                                </Border>
                            </Grid>
                        </Grid>
                        <Border Padding="8,4"
                                CornerRadius="999"
                                Background="#F8E7B4"
                                BorderBrush="#E4B95F"
                                BorderThickness="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,4,2,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="★" Foreground="#9A5A00" FontSize="13" FontWeight="Black"/>
                        </Border>
                        <CheckBox IsChecked="{Binding IsSelectedForBatch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource BatchSelectCheckBox}"
                                  Visibility="{Binding IsBatchSelectionUiVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                                  Checked="BatchSelection_Changed"
                                  Unchecked="BatchSelection_Changed"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Margin="6,6,0,0"/>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding Title}" FontWeight="Black" FontSize="14" Foreground="#25211E" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                        <TextBlock Text="{Binding Author}" Margin="0,4,0,0" Foreground="#81756B" FontSize="12" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                        <TextBlock Text="{Binding LibraryMetaText}" Margin="0,7,0,0" Foreground="#7E6A58" FontSize="12" FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding MissingText}" Foreground="#B44A36" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,6,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding HiddenText}" Foreground="#9A6F25" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,6,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding TagItems}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,5,5" Padding="7,3" CornerRadius="10" Background="{Binding Color}">
                                        <TextBlock Text="{Binding Name}" FontSize="10" Foreground="#2B2520"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HomeWideBookTemplate">
            <Border Width="360" Height="208" Margin="0,0,12,0" CornerRadius="11" Background="#26201B" BorderBrush="#22FFFFFF" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="HomeBook_Click" ClipToBounds="True"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2D241E" Offset="0"/>
                            <GradientStop Color="#171310" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill" Opacity="0.34"/>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#E61C1713" Offset="0"/>
                                <GradientStop Color="#B8191512" Offset="0.52"/>
                                <GradientStop Color="#33110D0A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Grid Margin="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="104"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="92" Height="138" CornerRadius="16" Background="{Binding BookAccentColor}" ClipToBounds="True" VerticalAlignment="Center" Effect="{StaticResource BookShadow}">
                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                        </Border>
                        <Grid Grid.Column="1" Margin="12,4,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="继续阅读" Foreground="#CFB9A6" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="{Binding Title}" Margin="0,10,0,0" Foreground="#FAF5EF" FontSize="22" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="2" Text="{Binding Author}" Margin="0,7,0,0" Foreground="#D6C7BA" FontSize="13" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="3" Text="{Binding ReadingMetaText}" Margin="0,12,0,0" Foreground="#F0E5DA" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <Border Grid.Row="4" Margin="0,10,0,0" Padding="12,6" CornerRadius="12" Background="#F6E7D6" HorizontalAlignment="Left">
                                <TextBlock Text="继续阅读" Foreground="#1D1714" FontSize="12" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Grid>
                    <Border Padding="9,5"
                            CornerRadius="999"
                            Background="#F8E7B4"
                            BorderBrush="#E4B95F"
                            BorderThickness="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,14,14,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="★" Foreground="#9A5A00" FontSize="14" FontWeight="Black"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HomeCompactBookTemplate">
            <Border Width="286" Height="104" Margin="0,0,14,0" Padding="10" CornerRadius="9" Background="#FDFBF8" BorderBrush="#55FFFFFF" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="HomeBook_Click"
                    Loaded="BookCoverHost_Loaded"
                    Unloaded="BookCoverHost_Unloaded">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="68" Height="84" CornerRadius="12" Background="{Binding BookAccentColor}" ClipToBounds="True" VerticalAlignment="Center">
                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                    </Border>
                    <Border Padding="6,2"
                            CornerRadius="999"
                            Background="#F8E7B4"
                            BorderBrush="#E4B95F"
                            BorderThickness="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="48,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="★" Foreground="#9A5A00" FontSize="11" FontWeight="Black"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,4,0,0">
                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Black" Foreground="#25211E" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Author}" Margin="0,4,0,0" Foreground="#7B7068" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding ReadingMetaText}" Margin="0,6,0,0" Foreground="#9A5A36" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0"/>
                <GradientStop Color="#F3F4F6" Offset="0.55"/>
                <GradientStop Color="#EEF2F7" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="DetailColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="18" Padding="16" CornerRadius="12" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" Effect="{StaticResource PanelShadow}">
            <DockPanel LastChildFill="True">
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,24">
                            <Border Width="46" Height="46" CornerRadius="15">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F18A56" Offset="0"/>
                                        <GradientStop Color="#A66DF2" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="漫" Foreground="White" FontSize="23" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="12,2,0,0">
                                <TextBlock Text="漫画库" FontSize="21" FontWeight="Black" Foreground="#25211E"/>
                                <TextBlock x:Name="VersionText" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Padding="12,10" CornerRadius="14" Background="#F3F4F6" Margin="0,0,0,18">
                            <TextBlock Text="快速入口" Foreground="#6B7280" FontSize="13"/>
                        </Border>

                        <TextBlock Text="浏览" Foreground="#81756B" FontSize="12" FontWeight="SemiBold" Margin="4,0,0,8"/>
                        <Button x:Name="HomeNavButton" Content="主页" Click="NavHome_Click" Style="{StaticResource SidebarNavButton}"/>
                        <Button x:Name="LibraryNavButton" Content="书库" Click="NavLibrary_Click" Style="{StaticResource SidebarNavButton}"/>
                        <Button x:Name="TagsNavButton" Content="标签" Click="NavTags_Click" Style="{StaticResource SidebarNavButton}"/>
                        <Button x:Name="AuthorsNavButton" Content="作者" Click="NavAuthors_Click" Style="{StaticResource SidebarNavButton}"/>

                        <TextBlock Text="工具" Foreground="#81756B" FontSize="12" FontWeight="SemiBold" Margin="4,0,0,8"/>
                        <Button Content="导入书库" Click="ChooseLibrary_Click" Style="{StaticResource SidebarActionButton}"/>
                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <Button Content="立即备份" Click="ManualBackup_Click" Style="{StaticResource SidebarActionButton}" Margin="0,0,2,4"/>
                            <Button Content="备份路径" Click="OpenBackupFolder_Click" Style="{StaticResource SidebarActionButton}" Margin="2,0,0,4"/>
                            <Button Content="指定数据" Click="ChooseDataFolder_Click" Style="{StaticResource SidebarActionButton}" Margin="0,0,2,0"/>
                            <Button Content="数据路径" Click="OpenDataFolder_Click" Style="{StaticResource SidebarActionButton}" Margin="2,0,0,0"/>
                        </UniformGrid>
                        <Button x:Name="CheckUpdateButton" Content="检查更新" Click="CheckUpdate_Click" Style="{StaticResource SidebarActionButton}" ToolTip="优先检查本机 _release/更新包或 git pull 后的本地源码；没有本地更新时才访问 GitHub。"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,18,0,0">
                    <Button x:Name="LogPanelToggleButton"
                            Content="日志"
                            Click="ToggleStatusPanel_Click"
                            Style="{StaticResource TinyButton}"
                            HorizontalAlignment="Left"/>
                    <Border x:Name="LogPanel"
                            Padding="12"
                            Margin="0,10,0,0"
                            CornerRadius="9"
                            Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="本地存档已启用" FontWeight="Bold" Foreground="#25211E"/>
                            <TextBlock x:Name="StoragePathText"
                                       Text="数据保存在软件同级目录"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="#8D8177"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="StatusText"
                               Margin="2,10,0,0"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#9A5A36"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="0,26,0,26">
            <Grid x:Name="HomePagePanel">
                <ScrollViewer x:Name="HomeMainScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="FastVerticalScrollViewer_PreviewMouseWheel">
                    <StackPanel Margin="8,0,22,12">
                        <Border x:Name="HomeEmptyState" Padding="26" CornerRadius="26" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" Effect="{StaticResource PanelShadow}" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="先导入一本漫画" FontSize="30" FontWeight="Black" Foreground="#111827"/>
                                    <TextBlock x:Name="HomeIntroText" Text="首页只有在有内容时才应该存在。现在先导入一本漫画，后面才会出现继续阅读、收藏和最近加入。" Margin="0,10,0,0" Foreground="#6B7280" FontSize="15" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <Button Content="导入漫画" Click="ChooseLibrary_Click" Margin="0,0,10,0"/>
                                    <Button Content="去漫画库" Click="NavLibrary_Click" Style="{StaticResource GhostButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="HomeSectionsPanel">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ContinueReadingBooks}" ItemTemplate="{StaticResource HomeWideBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="ContinueReadingEmptyText" Text="还没有可继续阅读的漫画，先打开一本书，主页就会把它放在这里。" Margin="4,10,0,0" Foreground="#8A7F77" Visibility="Collapsed"/>

                        <TextBlock Text="之前读过" Margin="4,28,0,14" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding RecentReadingBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="RecentReadingEmptyText" Text="还没有阅读记录，读过的漫画会出现在这里。" Margin="4,10,0,0" Foreground="#8A7F77" Visibility="Collapsed"/>

                        <TextBlock Text="收藏" Margin="4,28,0,14" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding FavoriteShowcaseBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="FavoriteShowcaseEmptyText" Text="还没有收藏作品，先在书库里挑几本真正想反复回看的漫画。" Margin="4,10,0,0" Foreground="#8A7F77" Visibility="Collapsed"/>

                        <TextBlock Text="最近加入" Margin="4,28,0,14" FontSize="28" FontWeight="Black" Foreground="#25211E"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled" PreviewMouseWheel="HorizontalShelfScrollViewer_PreviewMouseWheel">
                            <ItemsControl ItemsSource="{Binding RecentlyAddedBooks}" ItemTemplate="{StaticResource HomeCompactBookTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="RecentlyAddedEmptyText" Text="这里还没有新加入的漫画，导入书库后会自动出现。" Margin="4,10,0,0" Foreground="#8A7F77" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="LibraryPagePanel"
                  Visibility="Collapsed"
                  Background="Transparent"
                  MouseDown="LibraryArea_MouseDown"
                  AllowDrop="True"
                  DragEnter="LibraryPagePanel_DragEnter"
                  DragOver="LibraryPagePanel_DragOver"
                  DragLeave="LibraryPagePanel_DragLeave"
                  Drop="LibraryPagePanel_Drop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="LibraryFilterPanel" Grid.Row="0" Margin="8,0,22,16" Padding="16" CornerRadius="10" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FilterSummaryText" Text="当前显示全部漫画" VerticalAlignment="Center" Foreground="#B45309" FontSize="12" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel x:Name="LibraryMetricPanel" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="当前" Foreground="#8D8177" FontSize="12" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="VisibleBookCountText" Text="0 本" Foreground="#25211E" FontSize="13" FontWeight="Black"/>
                                            <TextBlock x:Name="TotalBookCountText" Text=" / 共 0 本" Foreground="#8D8177" FontSize="12" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="收藏" Foreground="#9A5A36" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="FavoriteCountText" Text="0 本" Foreground="#25211E" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="在读" Foreground="#447154" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="ReadingNowCountText" Text="0 本" Foreground="#25211E" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="4,0" Background="Transparent" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="已读" Foreground="#6B7280" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="FinishedCountText" Text="0 本" Foreground="#25211E" FontSize="13" FontWeight="Black"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Button x:Name="LibraryChromeToggleButton" Content="专注浏览" Click="ToggleLibraryChrome_Click" Style="{StaticResource GhostButton}"/>
                            </StackPanel>
                        </Grid>
                        <WrapPanel x:Name="LibraryFilterControlsPanel" Grid.Row="1" VerticalAlignment="Center" ItemHeight="44">
                            <TextBox x:Name="BookSearchBox" Width="280" Height="44" Margin="0,0,10,0" TextChanged="BookSearchBox_TextChanged" Style="{StaticResource FilterPillTextBox}" ToolTip="搜索标题、作者、标签"/>
                            <ComboBox x:Name="AuthorFilterBox" Width="156" Height="44" Margin="0,0,10,0" ItemsSource="{Binding AuthorFilters}" SelectionChanged="BookFilter_Changed" Style="{StaticResource FilterPillComboBox}"/>
                            <ComboBox x:Name="StatusFilterBox" Width="148" Height="44" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="BookFilter_Changed" Style="{StaticResource FilterPillComboBox}">
                                <ComboBoxItem Content="状态：全部"/>
                                <ComboBoxItem Content="状态：未读"/>
                                <ComboBoxItem Content="状态：在读"/>
                                <ComboBoxItem Content="状态：已读"/>
                                <ComboBoxItem Content="状态：搁置"/>
                            </ComboBox>
                            <CheckBox x:Name="FavoriteOnlyBox" Content="只看收藏" Margin="0,0,10,0" Checked="BookFilter_Changed" Unchecked="BookFilter_Changed"/>
                            <ComboBox x:Name="SortBox" Width="174" Height="44" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="SortBox_SelectionChanged" Style="{StaticResource FilterPillComboBox}">
                                <ComboBoxItem Content="排序：标题"/>
                                <ComboBoxItem Content="排序：进度"/>
                                <ComboBoxItem Content="排序：页数"/>
                                <ComboBoxItem Content="排序：容量"/>
                                <ComboBoxItem Content="排序：阅读次数"/>
                                <ComboBoxItem Content="排序：录入时间"/>
                                <ComboBoxItem Content="排序：出品时间"/>
                            </ComboBox>
                            <Button x:Name="BatchModeToggleButton" Content="多选管理" Click="ToggleBatchSelectionMode_Click" Style="{StaticResource FilterPillButton}" Height="44" Margin="0,0,10,0"/>
                            <Button Content="清空筛选" Click="ClearFilters_Click" Style="{StaticResource FilterPillButton}" Height="44"/>
                        </WrapPanel>
                        <Border x:Name="BatchManageShell" Grid.Row="2" Margin="0,10,0,0" Padding="8" CornerRadius="12" Background="#EEF2F7" BorderBrush="#DDE4EE" BorderThickness="1" Visibility="Collapsed">
