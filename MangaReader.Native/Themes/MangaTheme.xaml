<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.AppBackground">#F6F7F9</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceMuted">#F8FAFC</Color>
    <Color x:Key="Color.SurfaceWarm">#F8F2EC</Color>
    <Color x:Key="Color.TextPrimary">#111827</Color>
    <Color x:Key="Color.TextWarm">#25211E</Color>
    <Color x:Key="Color.TextMuted">#6B7280</Color>
    <Color x:Key="Color.TextSubtle">#8D8177</Color>
    <Color x:Key="Color.BorderSubtle">#E5E7EB</Color>
    <Color x:Key="Color.BorderStrong">#D1D5DB</Color>
    <Color x:Key="Color.Accent">#B45309</Color>
    <Color x:Key="Color.Danger">#9F1239</Color>
    <Color x:Key="Color.DangerSurface">#FFF1F2</Color>
    <Color x:Key="Color.DangerBorder">#FECDD3</Color>
    <Color x:Key="Color.ScrollTrack">#EEF2F7</Color>
    <Color x:Key="Color.ScrollThumb">#CBD5E1</Color>
    <Color x:Key="Color.ScrollThumbHover">#94A3B8</Color>

    <SolidColorBrush x:Key="Brush.AppBackground" Color="{StaticResource Color.AppBackground}"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="{StaticResource Color.SurfaceMuted}"/>
    <SolidColorBrush x:Key="Brush.SurfaceWarm" Color="{StaticResource Color.SurfaceWarm}"/>
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="Brush.TextWarm" Color="{StaticResource Color.TextWarm}"/>
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}"/>
    <SolidColorBrush x:Key="Brush.TextSubtle" Color="{StaticResource Color.TextSubtle}"/>
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="{StaticResource Color.BorderSubtle}"/>
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="Brush.DangerSurface" Color="{StaticResource Color.DangerSurface}"/>
    <SolidColorBrush x:Key="Brush.DangerBorder" Color="{StaticResource Color.DangerBorder}"/>
    <SolidColorBrush x:Key="Brush.ScrollTrack" Color="{StaticResource Color.ScrollTrack}"/>
    <SolidColorBrush x:Key="Brush.ScrollThumb" Color="{StaticResource Color.ScrollThumb}"/>
    <SolidColorBrush x:Key="Brush.ScrollThumbHover" Color="{StaticResource Color.ScrollThumbHover}"/>

    <CornerRadius x:Key="RadiusClip">4</CornerRadius>
    <CornerRadius x:Key="RadiusProgress">5</CornerRadius>
    <CornerRadius x:Key="RadiusControl">9</CornerRadius>
    <CornerRadius x:Key="RadiusPanel">10</CornerRadius>
    <CornerRadius x:Key="RadiusField">11</CornerRadius>
    <CornerRadius x:Key="RadiusTag">16</CornerRadius>
    <CornerRadius x:Key="RadiusColorSwatch">18</CornerRadius>
    <CornerRadius x:Key="RadiusComboPopup">18</CornerRadius>
    <CornerRadius x:Key="RadiusDialog">32</CornerRadius>
    <CornerRadius x:Key="RadiusDialogShadow">36</CornerRadius>
    <CornerRadius x:Key="RadiusScrollTrack">2</CornerRadius>
    <CornerRadius x:Key="RadiusScrollThumb">3</CornerRadius>

    <Thickness x:Key="SpacePanel">16</Thickness>
    <Thickness x:Key="SpaceDialog">24</Thickness>

    <Style x:Key="AppButton" TargetType="{x:Type Button}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Surface}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusControl}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppGhostButton" TargetType="{x:Type Button}" BasedOn="{StaticResource AppButton}">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
    </Style>

    <Style x:Key="AppDangerButton" TargetType="{x:Type Button}" BasedOn="{StaticResource AppButton}">
        <Setter Property="Background" Value="{StaticResource Brush.DangerSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.DangerBorder}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
    </Style>

    <Style x:Key="InvisibleScrollRepeatButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MinimalVerticalScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Background" Value="{StaticResource Brush.ScrollThumb}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid Background="Transparent">
                        <Border x:Name="ThumbRoot"
                                Width="6"
                                HorizontalAlignment="Right"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusScrollThumb}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Brush.ScrollThumbHover}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Brush.TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MinimalHorizontalScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="MinWidth" Value="24"/>
        <Setter Property="Background" Value="{StaticResource Brush.ScrollThumb}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid Background="Transparent">
                        <Border x:Name="ThumbRoot"
                                Height="6"
                                VerticalAlignment="Bottom"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusScrollThumb}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Brush.ScrollThumbHover}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Brush.TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
            <Border Width="6"
                    HorizontalAlignment="Right"
                    Background="{StaticResource Brush.ScrollTrack}"
                    CornerRadius="{StaticResource RadiusScrollTrack}"/>
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource InvisibleScrollRepeatButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource MinimalVerticalScrollThumb}"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource InvisibleScrollRepeatButton}"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Height="{TemplateBinding Height}" Background="{TemplateBinding Background}">
            <Border Height="6"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource Brush.ScrollTrack}"
                    CornerRadius="{StaticResource RadiusScrollTrack}"/>
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource InvisibleScrollRepeatButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource MinimalHorizontalScrollThumb}"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource InvisibleScrollRepeatButton}"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="18"/>
        <Setter Property="MinWidth" Value="18"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="MinHeight" Value="18"/>
                <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ColorSwatchBorderStyle" TargetType="Border">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusColorSwatch}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.82"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AddColorSwatchBorderStyle" TargetType="Border" BasedOn="{StaticResource ColorSwatchBorderStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

    <Style x:Key="AppDialogButton" TargetType="Button" BasedOn="{StaticResource AppButton}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="MinWidth" Value="104"/>
        <Setter Property="Padding" Value="18,0"/>
    </Style>

    <Style x:Key="AppDialogGhostButton" TargetType="Button" BasedOn="{StaticResource AppGhostButton}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="MinWidth" Value="104"/>
        <Setter Property="Padding" Value="18,0"/>
    </Style>

    <Style x:Key="AppDialogCloseButton" TargetType="Button" BasedOn="{StaticResource AppDialogGhostButton}">
        <Setter Property="Width" Value="40"/>
        <Setter Property="MinWidth" Value="40"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <Style x:Key="AppDialogTextBox" TargetType="TextBox">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            CornerRadius="{StaticResource RadiusControl}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}"/>
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Surface}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppDialogTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="34"/>
    </Style>

    <Style x:Key="AppDialogSubtitleText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="AppDialogLabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="AppDialogPanelBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPanel}"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="AppDialogListItemBorder" TargetType="Border" BasedOn="{StaticResource AppDialogPanelBorder}">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
        <Setter Property="Padding" Value="14"/>
    </Style>
</ResourceDictionary>
