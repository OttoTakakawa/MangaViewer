<Window x:Class="MangaReader.Native.MiscTagManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="杂图 Tag 管理"
        Width="920"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        ResizeMode="CanResize"
        MinWidth="720"
        MinHeight="480"
        ShowInTaskbar="False">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="0"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <StackPanel Grid.Row="0" Margin="26,22,26,8">
                    <TextBlock Text="杂图 Tag 管理" Style="{StaticResource AppDialogTitleText}"/>
                    <TextBlock Text="杂图库的独立 tag 体系，与漫画 tag 完全隔离。重命名 / 删除将自动同步到所有杂图记录。"
                               Style="{StaticResource AppDialogSubtitleText}"/>
                </StackPanel>

                <!-- 统计 + 工具栏 -->
                <Grid Grid.Row="1" Margin="26,0,26,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource MetricCard}" Margin="0,0,10,0" Padding="14,8">
                        <StackPanel>
                            <TextBlock Text="全部 Tag" Foreground="{DynamicResource Brush.TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TotalCountText" Text="0 个" Margin="0,4,0,0" FontSize="20" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource MetricCard}" Margin="0,0,10,0" Padding="14,8">
                        <StackPanel>
                            <TextBlock Text="分组数" Foreground="{DynamicResource Brush.TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="GroupCountText" Text="0 组" Margin="0,4,0,0" FontSize="20" FontWeight="Black" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <TextBox Grid.Column="2"
                             x:Name="SearchBox"
                             Height="36"
                             VerticalContentAlignment="Center"
                             Margin="10,0,10,0"
                             TextChanged="SearchBox_TextChanged"
                             Style="{StaticResource FilterTextBox}"
                             ToolTip="按名称或分类搜索"/>
                    <ComboBox Grid.Column="3"
                              x:Name="GroupFilterBox"
                              Width="140"
                              Height="36"
                              Margin="0,0,10,0"
                              SelectedIndex="0"
                              SelectionChanged="GroupFilter_Changed"
                              Style="{StaticResource FilterComboBox}">
                        <ComboBoxItem Content="全部分组"/>
                    </ComboBox>
                    <Button Grid.Column="4"
                            Content="新建 Tag"
                            Click="CreateTag_Click"
                            Style="{StaticResource HeaderActionButton}"/>
                </Grid>

                <!-- 列表 -->
                <Grid Grid.Row="2" Margin="26,0,26,12">
                    <Border Padding="0" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.SurfaceMuted}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                        <ListBox x:Name="TagList"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 Focusable="False">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="10,8,10,0" Padding="14" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="编辑"
                                                        Click="EditTag_Click"
                                                        Style="{StaticResource AppGhostButton}"
                                                        Margin="0,0,6,0"
                                                        Padding="10,4"/>
                                                <Button Content="删除"
                                                        Click="DeleteTag_Click"
                                                        Style="{StaticResource AppDangerButton}"
                                                        Padding="10,4"/>
                                            </StackPanel>
                                            <StackPanel VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{Binding Color}" CornerRadius="3" Padding="10,3" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Category}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                                </StackPanel>
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12">
                                                    <Run Text="已关联 "/>
                                                    <Run Text="{Binding UsageCount}"/>
                                                    <Run Text=" 张杂图"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding Color, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    <Border x:Name="EmptyState" Visibility="Collapsed" Padding="20" CornerRadius="{StaticResource RadiusPanel}" Background="{DynamicResource Brush.SurfaceMuted}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="当前没有任何杂图 Tag。点击右上角「新建 Tag」开始建立分类。"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

                <!-- 底部关闭按钮 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="26,8,26,18">
                    <Button Content="关闭" Width="104" Click="Close_Click" Style="{StaticResource AppDialogGhostButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
