<Window x:Class="MangaReader.Native.ReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="阅读器" Height="900" Width="1280" MinHeight="720" MinWidth="980"
        Background="#0F1115" WindowStartupLocation="CenterOwner" Opacity="1">
    <Window.Resources>
        <DropShadowEffect x:Key="ToolbarShadow" Color="#000000" BlurRadius="26" ShadowDepth="8" Opacity="0.28"/>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="#1A0F172A"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#33475569"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6694A3B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#4F1E293B"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#88CBD5E1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot">
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 4 4 L 8 0"
                                          Stroke="#CBD5E1"
                                          StrokeThickness="1.7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=ComboRoot}"
                                   Placement="Top"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,0,0,8"
                                        Width="{Binding ActualWidth, ElementName=ComboRoot}"
                                        Background="#111827"
                                        BorderBrush="#273244"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Effect="{StaticResource ToolbarShadow}">
                                    <ScrollViewer MaxHeight="240">
                                        <ItemsPresenter Margin="5"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#30FFFFFF"/>
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="11,8"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot" Margin="2" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#263244"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#334155"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track" VerticalAlignment="Center" Height="22">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsTabStop="False" Focusable="False" Height="4" Background="#E5E7EB" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="#E5E7EB"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsTabStop="False" Focusable="False" Height="4" Background="#30FFFFFF" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="#30FFFFFF"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" Background="#FFFFFF">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="16" Height="16" CornerRadius="8" Background="#FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="ReaderRoot" Background="#050608" PreviewMouseMove="ReaderRoot_PreviewMouseMove">
        <Border x:Name="ReaderBackdrop" Margin="0" Background="#050608">
            <ScrollViewer x:Name="ReaderScrollViewer"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"
                          Background="#050608"
                          Padding="6"
                          PreviewMouseWheel="ReaderScrollViewer_PreviewMouseWheel"
                          PreviewMouseLeftButtonDown="ReaderScrollViewer_PreviewMouseLeftButtonDown"
                          PreviewMouseLeftButtonUp="ReaderScrollViewer_PreviewMouseLeftButtonUp"
                          PreviewMouseRightButtonDown="ReaderScrollViewer_PreviewMouseRightButtonDown"
                          PreviewMouseRightButtonUp="ReaderScrollViewer_PreviewMouseRightButtonUp"
                          PreviewMouseMove="ReaderScrollViewer_PreviewMouseMove">
                <Grid x:Name="ImageScrollContent">
                    <StackPanel x:Name="ImageHost"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#FDFBF7">
                        <Image x:Name="ReaderImage" Margin="4" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Image x:Name="ReaderImageRight" Margin="4" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel.LayoutTransform>
                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                        </StackPanel.LayoutTransform>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border x:Name="ReaderMessagePanel"
                Panel.ZIndex="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="680"
                Padding="22,18"
                CornerRadius="24"
                Background="#EAFDFBF7"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                Visibility="Collapsed"
                Effect="{StaticResource ToolbarShadow}">
            <StackPanel>
                <TextBlock x:Name="ReaderMessageTitle"
                           Text="正在读取页面"
                           FontSize="20"
                           FontWeight="Black"
                           Foreground="#111827"
                           TextAlignment="Center"/>
                <TextBlock x:Name="ReaderMessageText"
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#475569"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid x:Name="NextBookConfirmOverlay"
              Panel.ZIndex="18"
              Background="#66000000"
              Visibility="Collapsed"
              PreviewMouseWheel="NextBookConfirmOverlay_PreviewMouseWheel">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="520"
                    Padding="22"
                    CornerRadius="26"
                    Background="#EA080A0E"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    Effect="{StaticResource ToolbarShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="已经读到最后一页"
                               FontSize="20"
                               FontWeight="Black"
                               Foreground="#F9FAFB"/>
                    <TextBlock x:Name="NextBookConfirmText"
                               Grid.Row="1"
                               Margin="0,12,0,0"
                               FontSize="13"
                               LineHeight="22"
                               Foreground="#CBD5E1"
                               TextWrapping="Wrap"/>
                    <StackPanel Grid.Row="2"
                                Margin="0,20,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="留在当前页"
                                Background="#1AFFFFFF"
                                BorderBrush="#22FFFFFF"
                                Click="NextBookCancel_Click"/>
                        <Button Content="前往下一本"
                                Margin="8,3,3,3"
                                Background="#F8FAFC"
                                BorderBrush="#F8FAFC"
                                Foreground="#0F172A"
                                Click="NextBookConfirm_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="TopToolbar"
                Panel.ZIndex="10"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,14,0,0"
                Padding="18,9"
                Background="#A6080A0E"
                BorderBrush="#18FFFFFF"
                BorderThickness="1"
                CornerRadius="22"
                Effect="{StaticResource ToolbarShadow}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Foreground="#F9FAFB" FontSize="14" FontWeight="SemiBold" MaxWidth="520" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <Border Width="1" Height="14" Margin="12,0" Background="#28FFFFFF"/>
                <TextBlock x:Name="PageText" Foreground="#CBD5E1" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border x:Name="BottomToolbar"
                Panel.ZIndex="10"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,18"
                Padding="12,9"
                Background="#B0080A0E"
                BorderBrush="#18FFFFFF"
                BorderThickness="1"
                CornerRadius="25"
                Effect="{StaticResource ToolbarShadow}">
            <Grid Width="1120">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button x:Name="PreviousPageButton" Content="上一页" Click="PreviousPage_Click"/>
                    <Button x:Name="NextPageButton" Content="下一页" Click="NextPage_Click"/>
                    <Button x:Name="FitWidthButton" Content="适宽" Click="FitWidth_Click"/>
                    <Button x:Name="FitHeightButton" Content="适高" Click="FitHeight_Click"/>
                    <Button x:Name="BackgroundButton" Content="背景" Click="CycleBackgroundButton_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock x:Name="BottomPageText" Text="1 / 1" Foreground="#F9FAFB" VerticalAlignment="Center" FontSize="12" FontWeight="Black" Margin="0,0,10,0"/>
                    <TextBlock x:Name="ZoomText" Text="100%" Foreground="#CBD5E1" VerticalAlignment="Center" MinWidth="78"/>
                </StackPanel>
                <Slider Grid.Column="2" x:Name="ZoomSlider" Minimum="0.05" Maximum="3" Value="1" TickFrequency="0.1" ValueChanged="ZoomSlider_ValueChanged" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="3" x:Name="DoublePageGapText" Text="间距 8" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,10,0" MinWidth="54"/>
                <Slider Grid.Column="4" x:Name="DoublePageGapSlider" Minimum="0" Maximum="80" Value="8" TickFrequency="2" ValueChanged="DoublePageGapSlider_ValueChanged" Margin="0,0,14,0" Focusable="False"/>
                <StackPanel Grid.Column="5" Orientation="Horizontal">
                    <ComboBox x:Name="WheelModeBox" Width="112" SelectionChanged="WheelModeBox_SelectionChanged">
                        <ComboBoxItem Content="滚轮翻页" IsSelected="True"/>
                        <ComboBoxItem Content="滚轮缩放"/>
                        <ComboBoxItem Content="滚轮滚动"/>
                    </ComboBox>
                    <ComboBox x:Name="ReadingModeBox" Width="84" SelectionChanged="ReadingModeBox_SelectionChanged">
                        <ComboBoxItem Content="单页" IsSelected="True"/>
                        <ComboBoxItem Content="双页"/>
                    </ComboBox>
                    <ComboBox x:Name="DirectionBox" Width="104" SelectionChanged="ReadingModeBox_SelectionChanged">
                        <ComboBoxItem Content="从左到右" IsSelected="True"/>
                        <ComboBoxItem Content="从右到左"/>
                    </ComboBox>
                    <Button x:Name="ToggleControlsButton" Content="隐藏" Click="ToggleControlsButton_Click"/>
                    <Button x:Name="FullscreenButton" Content="全屏" Click="FullscreenButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="HiddenControlsBadge"
                Panel.ZIndex="20"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="14,14,0,0"
                Padding="13,8"
                CornerRadius="18"
                Background="#99080A0E"
                BorderBrush="#18FFFFFF"
                BorderThickness="1"
                Visibility="Collapsed"
                MouseLeftButtonDown="HiddenControlsBadge_MouseLeftButtonDown">
            <StackPanel>
                <TextBlock Text="显示 UI" Foreground="#F9FAFB" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock x:Name="HiddenPageText" Text="1 / 1" Foreground="#CBD5E1" FontSize="11" FontWeight="SemiBold" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
