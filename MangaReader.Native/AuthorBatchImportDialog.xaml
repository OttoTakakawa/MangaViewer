<Window x:Class="MangaReader.Native.AuthorBatchImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MangaReader.Native.Models"
        Title="批量导入"
        Width="860"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="DialogShadow" Color="#111827" BlurRadius="40" ShadowDepth="12" Opacity="0.18"/>

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#111827"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="21" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogGhostButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <Style x:Key="DialogTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="CaretBrush" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root" CornerRadius="22" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9CA3AF"/>
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="32" Background="#F6F7F9" BorderBrush="#FFFFFF" BorderThickness="1" Padding="26" Effect="{StaticResource DialogShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <Button DockPanel.Dock="Right" Content="×" Width="42" MinWidth="42" Padding="0" Click="Cancel_Click" Style="{StaticResource DialogGhostButton}"/>
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="是否作为作者批量导入？" FontSize="30" FontWeight="Black" Foreground="#111827"/>
                    <TextBlock Text="确认作者名、逐本修正标题，然后一次性写入书库。" Margin="0,6,0,0" Foreground="#6B7280"/>
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="作者名" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox x:Name="AuthorBox" Margin="0,8,0,0" Style="{StaticResource DialogTextBox}"/>
                </StackPanel>
                <Border Grid.Column="2" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                    <StackPanel>
                        <TextBlock Text="识别目录" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="FolderCountText" Margin="0,6,0,0" FontSize="24" FontWeight="Black" Foreground="#111827"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                    <StackPanel>
                        <TextBlock Text="将导入" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="BookCountText" Margin="0,6,0,0" FontSize="24" FontWeight="Black" Foreground="#111827"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="标题可在导入前逐本修改；Tag 来自脚本预判，导入后仍可继续编辑。"
                       Margin="0,18,0,10"
                       Foreground="#6B7280"/>

            <Border Grid.Row="3" CornerRadius="24" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CandidateList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:BatchImportCandidate}">
                                <Border Margin="0,0,0,10" Padding="14" CornerRadius="18" Background="#F8FAFC" BorderBrush="#EEF2F7" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="210"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding FolderName}" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Style="{StaticResource DialogTextBox}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="18" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SummaryText}"
                                                       TextAlignment="Right"
                                                       Foreground="#374151"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <DockPanel Grid.Row="4" Margin="0,22,0,0">
                <TextBlock x:Name="HintText" Foreground="#6B7280" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Width="104" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource DialogGhostButton}"/>
                    <Button Content="确认导入" Width="124" Click="Confirm_Click" Style="{StaticResource DialogButton}"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
