<Window x:Class="MangaReader.Native.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="860"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="KeySlotButton" TargetType="Button" BasedOn="{StaticResource AppDialogGhostButton}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="NavListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="0,0,0,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
                                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}"/>
                    <TextBlock Text="设置" Style="{StaticResource AppDialogTitleText}"/>
                </DockPanel>

                <!-- 左导航 + 右内容 -->
                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="NavList"
                             Style="{StaticResource NavListBox}"
                             ItemContainerStyle="{StaticResource NavItem}"
                             SelectedIndex="0"
                             SelectionChanged="NavList_SelectionChanged">
                        <ListBoxItem Content="通用"/>
                        <ListBoxItem Content="阅读"/>
                        <ListBoxItem Content="数据"/>
                        <ListBoxItem Content="标记"/>
                        <ListBoxItem Content="危险"/>
                    </ListBox>

                    <ScrollViewer Grid.Column="1" Margin="20,0,0,0" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!-- 通用分区 -->
                            <StackPanel x:Name="SectionGeneral">
                                <TextBlock Text="通用设置" Style="{StaticResource SectionHeader}"/>
                                <CheckBox x:Name="PrivacyModeCheckBox" Content="隐私模式（隐藏所有作品封面）" FontSize="14" Margin="0,0,0,14" Checked="PrivacyModeCheckBox_Changed" Unchecked="PrivacyModeCheckBox_Changed"/>
                                <CheckBox x:Name="CatalogDeleteCheckBox" Content="在详情页目录右键中显示「删除源文件」" FontSize="14" Margin="0,0,0,14" Checked="CatalogDeleteCheckBox_Changed" Unchecked="CatalogDeleteCheckBox_Changed"/>
                                <CheckBox x:Name="WaterfallRightClickCheckBox" Content="启用瀑布流右键菜单（切换样式、隐藏、打开源文件夹等）" FontSize="14" Checked="WaterfallRightClickCheckBox_Changed" Unchecked="WaterfallRightClickCheckBox_Changed"/>
                            </StackPanel>

                            <!-- 阅读分区 -->
                            <StackPanel x:Name="SectionReading" Visibility="Collapsed">
                                <TextBlock Text="快捷键" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="下一页" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="NextKey1" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="next,0"/>
                                    <Button x:Name="NextKey2" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="next,1"/>
                                    <Button x:Name="NextKey3" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="next,2"/>
                                </StackPanel>

                                <TextBlock Text="上一页" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="PrevKey1" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="prev,0"/>
                                    <Button x:Name="PrevKey2" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="prev,1"/>
                                    <Button x:Name="PrevKey3" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="prev,2"/>
                                </StackPanel>

                                <TextBlock Text="全屏" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="FsKey1" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="fullscreen,0"/>
                                    <Button x:Name="FsKey2" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="fullscreen,1"/>
                                    <Button x:Name="FsKey3" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="fullscreen,2"/>
                                </StackPanel>

                                <TextBlock Text="隐藏界面" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="HideKey1" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="hideui,0"/>
                                    <Button x:Name="HideKey2" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="hideui,1"/>
                                    <Button x:Name="HideKey3" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="hideui,2"/>
                                </StackPanel>

                                <TextBlock Text="单页/双页" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Button x:Name="PagKey1" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="pagination,0"/>
                                    <Button x:Name="PagKey2" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="pagination,1"/>
                                    <Button x:Name="PagKey3" Content="—" Click="KeySlot_Click" Style="{StaticResource KeySlotButton}" Tag="pagination,2"/>
                                </StackPanel>

                                <TextBlock x:Name="KeyConflictWarning" Text="存在重复快捷键" Foreground="#EF4444" FontSize="11" Visibility="Collapsed" Margin="0,0,0,12"/>

                                <TextBlock Text="阅读偏好" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="滚轮" Style="{StaticResource AppDialogLabelText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="WheelModeComboBox" Grid.Column="1" Style="{StaticResource AppDialogComboBox}" Height="36" Margin="0,0,16,0">
                                        <ComboBoxItem Content="翻页"/>
                                        <ComboBoxItem Content="缩放"/>
                                        <ComboBoxItem Content="滚动"/>
                                    </ComboBox>
                                    <TextBlock Text="渲染" Style="{StaticResource AppDialogLabelText}" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="QualityModeComboBox" Grid.Column="3" Style="{StaticResource AppDialogComboBox}" Height="36" Margin="0,0,16,0">
                                        <ComboBoxItem Content="质量"/>
                                        <ComboBoxItem Content="性能"/>
                                    </ComboBox>
                                    <TextBlock Text="双页间距" Style="{StaticResource AppDialogLabelText}" Grid.Column="4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                                        <Slider x:Name="DoublePageGapSlider" Width="100" Minimum="0" Maximum="80" Value="8" TickPlacement="None" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="DoublePageGapLabel" Text="8" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="20"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- 数据分区 -->
                            <StackPanel x:Name="SectionData" Visibility="Collapsed">
                                <TextBlock Text="数据管理" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="数据根目录" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="DataRootTextBox" IsReadOnly="True" Style="{StaticResource AppDialogTextBox}" TextWrapping="Wrap"/>
                                        <Button Grid.Column="1" Content="更改" Click="ChangeDataRoot_Click" Style="{StaticResource AppDialogGhostButton}" Margin="8,0,0,0"/>
                                    </Grid>
                                    <TextBlock Text="更改后需要重启软件生效" Foreground="{StaticResource Brush.TextMuted}" FontSize="11" Margin="0,6,0,0"/>
                                </StackPanel>
                                <WrapPanel>
                                    <Button Content="打开备份目录" Click="OpenBackupFolder_Click" Style="{StaticResource AppDialogGhostButton}" MinWidth="0" Margin="0,0,8,0"/>
                                    <Button Content="打开数据目录" Click="OpenDataFolder_Click" Style="{StaticResource AppDialogGhostButton}" MinWidth="0" Margin="0,0,8,0"/>
                                    <Button Content="手动备份" Click="CreateBackup_Click" Style="{StaticResource AppDialogGhostButton}" MinWidth="0" Margin="0,0,8,0"/>
                                    <Button Content="恢复备份" Click="OpenDataSafety_Click" Style="{StaticResource AppDialogGhostButton}" MinWidth="0"/>
                                </WrapPanel>
                            </StackPanel>

                            <!-- 标记分区 -->
                            <StackPanel x:Name="SectionTags" Visibility="Collapsed">
                                <TextBlock Text="标记颜色组" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <RadioButton x:Name="ColorGroupARadio" Content="颜色组 A" IsChecked="True" FontSize="14" Margin="0,0,16,0" Checked="ColorGroup_Checked"/>
                                    <RadioButton x:Name="ColorGroupBRadio" Content="颜色组 B" FontSize="14" Margin="0,0,16,0" Checked="ColorGroup_Checked"/>
                                    <RadioButton x:Name="ColorGroupCRadio" Content="颜色组 C" FontSize="14" Margin="0,0,16,0" Checked="ColorGroup_Checked"/>
                                    <RadioButton x:Name="ColorGroupDRadio" Content="颜色组 D" FontSize="14" Checked="ColorGroup_Checked"/>
                                </StackPanel>
                                <WrapPanel x:Name="ColorSwatchPanel" Margin="0,0,0,16"/>
                                <TextBlock Text="一本书的标记超过 12 个后从第一个颜色重新循环" Foreground="{StaticResource Brush.TextMuted}" FontSize="11"/>
                            </StackPanel>

                            <!-- 危险分区 -->
                            <StackPanel x:Name="SectionDanger" Visibility="Collapsed">
                                <TextBlock Text="危险操作" Style="{StaticResource SectionHeader}"/>

                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="权限密码" Style="{StaticResource AppDialogLabelText}" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="用于删除源文件等敏感操作" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button x:Name="ChangePasswordButton" Content="修改密码" Click="ChangePassword_Click" Style="{StaticResource AppDialogGhostButton}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Content="重置所有设置为默认" Click="ResetSettings_Click" Style="{StaticResource AppDialogDangerButton}"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <!-- 底部按钮 -->
                <DockPanel Grid.Row="2" Margin="0,20,0,0">
                    <Button DockPanel.Dock="Right" Content="保存" Click="Save_Click" Style="{StaticResource AppDialogButton}" Margin="8,0,0,0"/>
                    <Button DockPanel.Dock="Right" Content="取消" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}"/>
                    <TextBlock x:Name="UnsavedHint" Text="有未保存的更改" Foreground="#F97316" FontSize="12" VerticalAlignment="Center" Visibility="Collapsed"/>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
