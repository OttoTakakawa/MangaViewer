<Window x:Class="MangaReader.Native.TagEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MangaReader.Native.Models"
        Title="编辑标签"
        Width="620"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="DialogPillButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#26211D"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="BorderBrush" Value="#332C27"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="20"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A322B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15120F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogGhostButton" TargetType="Button" BasedOn="{StaticResource DialogPillButton}">
            <Setter Property="Background" Value="#ECE4DA"/>
            <Setter Property="Foreground" Value="#2A241F"/>
            <Setter Property="BorderBrush" Value="#DED3C7"/>
        </Style>

        <Style x:Key="DialogCloseButton" TargetType="Button" BasedOn="{StaticResource DialogGhostButton}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style x:Key="DialogTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#211D19"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="CaretBrush" Value="#F8F3EA"/>
            <Setter Property="BorderBrush" Value="#3A332D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="23"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Background" Value="#211D19"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#3A322B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#4A4037"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#211D19"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="BorderBrush" Value="#3A332D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="23"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="#3A332D"
                                                BorderThickness="1">
                                            <Grid>
                                                <ContentPresenter Margin="16,0,42,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <TextBlock Text="⌄" Foreground="#C8B9AA" FontSize="18" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,2"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,8,0,0"
                                        CornerRadius="18"
                                        Background="#211D19"
                                        BorderBrush="#3A332D"
                                        BorderThickness="1"
                                        Padding="6">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="32" Background="#F3EDE4" BorderBrush="#FFF8EF" BorderThickness="1" Padding="26">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="42" ShadowDepth="10" Opacity="0.22"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource DialogCloseButton}"/>
                <StackPanel>
                    <TextBlock Text="编辑标签" FontSize="30" FontWeight="Black" Foreground="#201B17"/>
                    <TextBlock x:Name="UpdatedAtText" Margin="0,6,0,0" Foreground="#7C6F64" FontSize="13"/>
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="156"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="标签名称" Foreground="#74685E" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox x:Name="TagNameBox" Margin="0,8,0,0" Style="{StaticResource DialogTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="标签分组（可输入自定义）" Foreground="#74685E" FontSize="12" FontWeight="SemiBold"/>
                    <ComboBox x:Name="TagCategoryBox" Margin="0,8,0,0" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" Style="{StaticResource DialogComboBox}">
                        <ComboBoxItem Content="内容形态"/>
                        <ComboBoxItem Content="色彩规格"/>
                        <ComboBoxItem Content="画质规格"/>
                        <ComboBoxItem Content="自定义"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="规则" Foreground="#74685E" FontSize="12" FontWeight="SemiBold"/>
                    <ComboBox x:Name="TagTypeBox" Margin="0,8,0,0" Style="{StaticResource DialogComboBox}">
                        <ComboBoxItem Content="互斥"/>
                        <ComboBoxItem Content="不互斥"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Margin="0,22,0,0">
                <TextBlock Text="标签颜色" Foreground="#74685E" FontSize="12" FontWeight="SemiBold"/>
                <ItemsControl x:Name="ColorPicker" Margin="0,10,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,8,8"
                                    Background="{Binding}" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click"
                                    BorderBrush="#3A332D" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border x:Name="SelectedColorPreview" Margin="0,8,0,0" Padding="12,6" CornerRadius="16" HorizontalAlignment="Left">
                    <TextBlock x:Name="SelectedColorText" FontSize="12" Foreground="#25211E"/>
                </Border>
            </StackPanel>

            <Border Grid.Row="3" Margin="0,18,0,0" Padding="18" CornerRadius="24" Background="#FFF9F0" BorderBrush="#E6D9CA" BorderThickness="1">
                <DockPanel LastChildFill="True">
                    <Button x:Name="MoreButton" DockPanel.Dock="Right" Content="更多" Width="88" Click="More_Click" Style="{StaticResource DialogPillButton}"/>
                    <StackPanel>
                        <TextBlock x:Name="UsageCountText" FontSize="19" FontWeight="Black" Foreground="#201B17"/>
                        <TextBlock Text="更多 = 按此标签筛选。即使没有关联漫画，也会进入空结果视图。"
                                   Margin="0,6,0,0"
                                   Foreground="#75685E"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="4" Margin="0,18,0,0" Padding="16" CornerRadius="24" Background="#E9DFD2" BorderBrush="#DED0C0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="关联漫画预览" FontSize="13" FontWeight="Bold" Foreground="#5E5249"/>
                    <TextBlock x:Name="EmptyPreviewText" Text="当前没有漫画使用这个标签。" Margin="0,14,0,0" Foreground="#7C6F64" Visibility="Collapsed"/>
                    <ItemsControl x:Name="PreviewBooksList" Margin="0,14,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:MangaBook}">
                                <StackPanel Width="118" Margin="0,0,14,0">
                                    <Border Width="104" Height="140" CornerRadius="18" Background="#D8CCBE" ClipToBounds="True">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}" Margin="2,8,0,0" FontSize="12" Foreground="#352E28" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="取消" Width="96" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource DialogGhostButton}"/>
                <Button Content="保存" Width="96" Click="Confirm_Click" Style="{StaticResource DialogPillButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
