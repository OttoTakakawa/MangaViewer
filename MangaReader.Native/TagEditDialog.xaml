<Window x:Class="MangaReader.Native.TagEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MangaReader.Native.Models"
        Title="编辑标签"
        Width="664"
        Height="604"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <DataTemplate x:Key="PreviewBookTemplate" DataType="{x:Type models:MangaBook}">
            <Border Margin="0,0,8,0" Padding="10,6" CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource Brush.SurfaceMuted}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1">
                <TextBlock Text="{Binding Title}" FontSize="12" Foreground="#374151" MaxWidth="160" TextTrimming="CharacterEllipsis"/>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Padding="26" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}"/>
                <TextBlock Text="编辑标签" Style="{StaticResource AppDialogTitleText}"/>
            </DockPanel>

            <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                <TextBlock x:Name="UpdatedAtText" Foreground="#9CA3AF" FontSize="12" Margin="0,0,12,0"/>
                <TextBlock x:Name="UsageCountText" Foreground="#9CA3AF" FontSize="12" Margin="0,0,12,0"/>
                <Button Content="查看关联的漫画 →" Click="More_Click" Style="{StaticResource AppDialogLinkButton}"/>
            </WrapPanel>

            <Grid Grid.Row="2" Margin="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="标签名称" Style="{StaticResource AppDialogLabelText}"/>
                    <TextBox x:Name="TagNameBox" Margin="0,8,0,0" Style="{StaticResource AppDialogTextBox}"/>
                </StackPanel>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="标签分组（可输入自定义）" Style="{StaticResource AppDialogLabelText}"/>
                        <ComboBox x:Name="TagCategoryBox" Margin="0,8,0,0" Style="{StaticResource AppDialogEditableComboBox}" SelectionChanged="TagCategoryBox_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="规则" Style="{StaticResource AppDialogLabelText}"/>
                        <ComboBox x:Name="TagTypeBox" Margin="0,8,0,0" Style="{StaticResource AppDialogComboBox}">
                            <ComboBoxItem Content="互斥"/>
                            <ComboBoxItem Content="不互斥"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,22,0,0">
                <TextBlock Text="标签颜色" Style="{StaticResource AppDialogLabelText}"/>
                <WrapPanel Margin="0,10,0,0">
                    <ItemsControl x:Name="PresetColorPicker">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ColorSwatchBorderStyle}"
                                        Background="{Binding}"
                                        MouseLeftButtonDown="ColorSwatch_Click"
                                        Margin="0,0,8,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Style="{StaticResource AddColorSwatchBorderStyle}"
                            Margin="0,0,8,0"
                            MouseLeftButtonDown="AddCustomColor_Click"
                            ToolTip="添加自定义颜色">
                        <TextBlock Text="+" Foreground="#9CA3AF" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ItemsControl x:Name="CustomColorPicker">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ColorSwatchBorderStyle}"
                                        Background="{Binding}"
                                        MouseLeftButtonDown="ColorSwatch_Click"
                                        Margin="0,0,8,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
                <Border x:Name="SelectedColorPreview" Margin="0,8,0,0" Padding="12,6" CornerRadius="{StaticResource RadiusTag}" HorizontalAlignment="Left" SnapsToDevicePixels="True">
                    <TextBlock x:Name="SelectedColorText" FontSize="12" Foreground="#374151"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,16,0,0">
                <TextBlock Text="已关联漫画预览" Style="{StaticResource AppDialogLabelText}"/>
                <ItemsControl x:Name="PreviewBooksList" Margin="0,8,0,0" ItemTemplate="{StaticResource PreviewBookTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock x:Name="EmptyPreviewText" Text="暂无关联漫画。" Foreground="#9CA3AF" FontSize="12" Margin="0,4,0,0" Visibility="Collapsed"/>
            </StackPanel>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,8">
                <Button Content="取消" Width="104" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}"/>
                <Button Content="保存" Width="104" Click="Confirm_Click" Style="{StaticResource AppDialogButton}"/>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</Window>
