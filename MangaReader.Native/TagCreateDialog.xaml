<Window x:Class="MangaReader.Native.TagCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建标签"
        Width="624"
        Height="564"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="DialogPillButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#26211D"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="BorderBrush" Value="#332C27"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="20"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A322B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15120F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogGhostButton" TargetType="Button" BasedOn="{StaticResource DialogPillButton}">
            <Setter Property="Background" Value="#ECE4DA"/>
            <Setter Property="Foreground" Value="#2A241F"/>
            <Setter Property="BorderBrush" Value="#DED3C7"/>
        </Style>

        <Style x:Key="DialogCloseButton" TargetType="Button" BasedOn="{StaticResource DialogGhostButton}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style x:Key="DialogTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#211D19"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="CaretBrush" Value="#F8F3EA"/>
            <Setter Property="BorderBrush" Value="#3A332D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="23"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Background" Value="#211D19"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#3A322B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#4A4037"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#211D19"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="BorderBrush" Value="#3A332D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="23"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="#3A332D"
                                                BorderThickness="1">
                                            <Grid>
                                                <ContentPresenter Margin="16,0,42,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <TextBlock Text="⌄" Foreground="#C8B9AA" FontSize="18" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,2"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,8,0,0"
                                        CornerRadius="18"
                                        Background="#211D19"
                                        BorderBrush="#3A332D"
                                        BorderThickness="1"
                                        Padding="6">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogEditableComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#211D19"/>
            <Setter Property="Foreground" Value="#F8F3EA"/>
            <Setter Property="BorderBrush" Value="#3A332D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border CornerRadius="23"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#3A332D"
                                    BorderThickness="1">
                                <Grid>
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Margin="16,0,42,0"
                                             VerticalAlignment="Center"
                                             Background="Transparent"
                                             Foreground="#F8F3EA"
                                             CaretBrush="#F8F3EA"
                                             BorderThickness="0"
                                             FontSize="14"
                                             Focusable="True"
                                             IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"
                                             Padding="0"/>
                                    <TextBlock Text="⌄" Foreground="#C8B9AA" FontSize="18" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,2" IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          IsHitTestVisible="False"
                                          HorizontalAlignment="Right"
                                          Width="42"
                                          Opacity="0"/>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,8,0,0"
                                        CornerRadius="18"
                                        Background="#211D19"
                                        BorderBrush="#3A332D"
                                        BorderThickness="1"
                                        Padding="6">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Border CornerRadius="36"
                Background="#01000000">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="42" ShadowDepth="10" Opacity="0.22"/>
            </Border.Effect>
        </Border>
        <Border CornerRadius="32" Background="#F3EDE4" BorderBrush="#FFF8EF" BorderThickness="1" Padding="26" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource DialogCloseButton}"/>
                <TextBlock Text="新建标签" FontSize="30" FontWeight="Black" Foreground="#201B17"/>
            </DockPanel>

            <TextBlock Grid.Row="1"
                       Text="互斥标签：同一分组只允许一本书保留一个；不互斥标签适合题材、主题、风格。"
                       Margin="0,8,0,0"
                       Foreground="#7C6F64"
                       TextWrapping="Wrap"/>

            <Grid Grid.Row="2" Margin="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="标签名称" Foreground="#74685E" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox x:Name="TagNameBox" Margin="0,8,0,0" Style="{StaticResource DialogTextBox}"/>
                </StackPanel>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="标签分组（可输入自定义）" Foreground="#74685E" FontSize="12" FontWeight="SemiBold"/>
                        <ComboBox x:Name="TagCategoryBox" Margin="0,8,0,0" Style="{StaticResource DialogEditableComboBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="规则" Foreground="#74685E" FontSize="12" FontWeight="SemiBold"/>
                        <ComboBox x:Name="TagTypeBox" Margin="0,8,0,0" Style="{StaticResource DialogComboBox}">
                            <ComboBoxItem Content="互斥"/>
                            <ComboBoxItem Content="不互斥"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,22,0,0">
                <TextBlock Text="标签颜色" Foreground="#74685E" FontSize="12" FontWeight="SemiBold"/>
                <ItemsControl x:Name="ColorPicker" Margin="0,10,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,8,8"
                                    Background="{Binding}" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click"
                                    BorderBrush="#3A332D" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border x:Name="SelectedColorPreview" Margin="0,8,0,0" Padding="12,6" CornerRadius="16" HorizontalAlignment="Left" SnapsToDevicePixels="True">
                    <TextBlock x:Name="SelectedColorText" FontSize="12" Foreground="#25211E"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="取消" Width="96" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource DialogGhostButton}"/>
                <Button Content="创建" Width="96" Click="Confirm_Click" Style="{StaticResource DialogPillButton}"/>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</Window>
