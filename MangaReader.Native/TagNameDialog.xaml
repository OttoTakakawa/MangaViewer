<Window x:Class="MangaReader.Native.TagNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑标签"
        Width="420"
        Height="210"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F1EB">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="编辑标签" FontSize="24" FontWeight="Black" Foreground="#25211E"/>
        <TextBlock Grid.Row="1"
                   Text="只修改标签名称；分类会根据内置预设或自定义规则自动归类。"
                   Margin="0,10,0,0"
                   Foreground="#6B7280"
                   TextWrapping="Wrap"/>
        <TextBox x:Name="TagNameBox"
                 Grid.Row="2"
                 Margin="0,18,0,0"
                 Height="42"
                 VerticalContentAlignment="Center"
                 FontSize="15"
                 Padding="14,0,14,0"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="取消" Width="88" Height="38" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="保存" Width="88" Height="38" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
