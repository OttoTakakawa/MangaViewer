<Window x:Class="MangaReader.Native.ImportSingleBookConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认导入"
        Width="680"
        Height="560"
        MinWidth="640"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="22">
        <Border Style="{StaticResource AppDialogShadowBorder}"/>
        <Border CornerRadius="{StaticResource RadiusDialog}"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="×" Click="Cancel_Click" Style="{StaticResource AppDialogCloseButton}"/>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="确认导入这本漫画？"
                                   Style="{StaticResource AppDialogTitleText}"/>
                        <TextBlock Text="导入前确认识别结果，可修改标题。只支持包含图片页的漫画文件夹。"
                                   Style="{StaticResource AppDialogSubtitleText}"/>
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,22,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Style="{StaticResource AppDialogPanelBorder}" Padding="16">
                            <StackPanel>
                                <TextBlock Text="漫画文件夹" Style="{StaticResource AppDialogLabelText}"/>
                                <TextBlock x:Name="FolderPathText"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           TextWrapping="Wrap"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="作品标题" Style="{StaticResource AppDialogLabelText}"/>
                            <TextBox x:Name="TitleBox"
                                     Margin="0,8,0,0"
                                     Style="{StaticResource AppDialogTextBox}"
                                     TextChanged="TitleBox_TextChanged"/>
                        </StackPanel>

                        <Border Margin="0,16,0,0" Style="{StaticResource AppDialogPanelBorder}" Padding="16">
                            <StackPanel>
                                <TextBlock Text="识别内容" Style="{StaticResource AppDialogLabelText}"/>
                                <TextBlock x:Name="SummaryText"
                                           Margin="0,10,0,0"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="TagsText"
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <DockPanel Grid.Row="2" Margin="0,18,0,0">
                    <TextBlock x:Name="HintText" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Width="104" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource AppDialogGhostButton}"/>
                        <Button x:Name="ConfirmButton" Content="确认导入" Width="124" Click="Confirm_Click" Style="{StaticResource AppDialogButton}"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
