<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MangaReader.Core.Models;assembly=MangaReader.Core"
        xmlns:local="clr-namespace:MangaReader.Avalonia"
        x:Class="MangaReader.Avalonia.MainWindow"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="680"
        Title="MangaReader"
        Background="{StaticResource Brush.AppBackground}">
  <Grid ColumnDefinitions="132,*">
    <Border Grid.Column="0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="0,0,1,0" Padding="14">
      <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
        <StackPanel>
          <TextBlock Text="Manga" FontSize="20" FontWeight="Black" Foreground="{StaticResource Brush.TextPrimary}"/>
          <TextBlock Text="Reader" FontSize="12" Foreground="{StaticResource Brush.TextSubtle}"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Spacing="8">
          <Button x:Name="HomeNavButton" Content="主页" Click="NavHome_Click" Height="32" HorizontalContentAlignment="Left"/>
          <Button x:Name="LibraryNavButton" Content="书库" Click="NavLibrary_Click" Height="32" HorizontalContentAlignment="Left"/>
          <Button x:Name="TagsNavButton" Content="标签" Click="NavTags_Click" Height="32" HorizontalContentAlignment="Left"/>
          <Button x:Name="AuthorsNavButton" Content="作者" Click="NavAuthors_Click" Height="32" HorizontalContentAlignment="Left"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Spacing="8">
          <Button Content="指定数据" Click="PickFolder_Click" Height="32" FontSize="12"/>
          <Button Content="检查更新" Click="OpenGitHub_Click" Height="32" FontSize="12"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
      <Border Grid.Row="0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="0,0,0,1" Padding="22,14">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
          <StackPanel>
            <TextBlock x:Name="PageTitleText" Text="书库" FontSize="22" FontWeight="Black" Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock x:Name="StatusText" Text="选择漫画根目录开始扫描。" Margin="0,4,0,0" Foreground="{StaticResource Brush.TextMuted}"/>
          </StackPanel>
          <Button Grid.Column="1" Content="导入漫画" Click="PickFolder_Click" Padding="16,8" Background="{StaticResource Brush.TextPrimary}" Foreground="{StaticResource Brush.Surface}"/>
          <Button Grid.Column="2" Content="重新扫描" Click="Rescan_Click" Padding="16,8"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1" x:Name="HomePagePanel" IsVisible="False" Margin="22">
        <Grid RowDefinitions="Auto,*" RowSpacing="16">
          <TextBlock Text="主页" FontSize="28" FontWeight="Black" Foreground="{StaticResource Brush.TextWarm}"/>
          <UniformGrid Grid.Row="1" Columns="3" Rows="1">
            <Border Margin="0,0,12,0" Padding="20" CornerRadius="10" Background="{StaticResource Brush.Surface}">
              <StackPanel>
                <TextBlock Text="书库作品" Foreground="{StaticResource Brush.TextMuted}"/>
                <TextBlock x:Name="HomeBookCountText" Text="0 本" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="{StaticResource Brush.TextPrimary}"/>
              </StackPanel>
            </Border>
            <Border Margin="0,0,12,0" Padding="20" CornerRadius="10" Background="{StaticResource Brush.Surface}">
              <StackPanel>
                <TextBlock Text="收藏作品" Foreground="{StaticResource Brush.TextMuted}"/>
                <TextBlock x:Name="HomeFavoriteCountText" Text="0 本" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Foreground="{StaticResource Brush.TextPrimary}"/>
              </StackPanel>
            </Border>
            <Border Padding="20" CornerRadius="10" Background="{StaticResource Brush.Surface}">
              <StackPanel>
                <TextBlock Text="数据目录" Foreground="{StaticResource Brush.TextMuted}"/>
                <TextBlock x:Name="HomeStorageText" Text="-" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{StaticResource Brush.TextPrimary}"/>
              </StackPanel>
            </Border>
          </UniformGrid>
        </Grid>
      </Grid>

      <Grid Grid.Row="1" x:Name="LibraryPagePanel" ColumnDefinitions="340,*">
        <Border Grid.Column="0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="16" Spacing="10">
            <TextBox x:Name="SearchBox"
                     Watermark="搜索标题、作者、标签"
                     TextChanged="SearchBox_TextChanged"/>
            <TextBox x:Name="TagSearchBox"
                     Watermark="按 Tag 筛选"
                     TextChanged="SearchBox_TextChanged"/>
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
              <ComboBox x:Name="SortBox" SelectedIndex="0" SelectionChanged="BookFilter_Changed">
                <ComboBoxItem Content="最近录入"/>
                <ComboBoxItem Content="标题"/>
                <ComboBoxItem Content="作者"/>
                <ComboBoxItem Content="页数"/>
              </ComboBox>
              <CheckBox Grid.Column="1" x:Name="FavoriteOnlyBox" Content="收藏" VerticalAlignment="Center" Checked="BookFilter_Changed" Unchecked="BookFilter_Changed"/>
              <CheckBox Grid.Column="2" x:Name="ShowHiddenBox" Content="隐藏" VerticalAlignment="Center" Checked="BookFilter_Changed" Unchecked="BookFilter_Changed"/>
            </Grid>
            <ComboBox x:Name="AuthorFilterBox" SelectedIndex="0" SelectionChanged="BookFilter_Changed"/>
            <ComboBox x:Name="StatusFilterBox" SelectedIndex="0" SelectionChanged="BookFilter_Changed">
              <ComboBoxItem Content="全部状态"/>
              <ComboBoxItem Content="未读"/>
              <ComboBoxItem Content="在读"/>
            </ComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock x:Name="ActiveTagSummaryText" Text="已选 0 个 Tag" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextMuted}"/>
              <Button Content="清除筛选" Click="ClearFilters_Click" Height="32" Padding="12,0"/>
            </StackPanel>
          </StackPanel>
          <ListBox x:Name="BooksList"
                   SelectionChanged="BooksList_SelectionChanged"
                   Padding="10,0,10,12">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:MangaBook">
                <Border Padding="10" Margin="0,0,0,8" CornerRadius="10" Background="{StaticResource Brush.SurfaceMuted}">
                  <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Author}" Margin="0,3,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding LibraryMetaText}" Margin="0,6,0,0" Foreground="{StaticResource Brush.TextSubtle}" FontSize="12"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <ScrollViewer Grid.Column="1">
        <Grid Margin="32" ColumnDefinitions="260,*" ColumnSpacing="40">
          <Border Width="260" Height="390" CornerRadius="14" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1" Background="{StaticResource Brush.Surface}">
            <Grid>
              <Image x:Name="CoverImage" Stretch="UniformToFill"/>
              <TextBlock x:Name="CoverPlaceholder" Text="暂无封面" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextSubtle}"/>
            </Grid>
          </Border>

          <StackPanel Grid.Column="1" Spacing="22">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
              <StackPanel>
                <TextBlock x:Name="TitleText" Text="未选择作品" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Brush.TextPrimary}" TextWrapping="Wrap"/>
                <TextBlock x:Name="AuthorText" Text="作者 -" Margin="0,8,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="15"/>
                <TextBlock x:Name="MetaText" Text="0 页" Margin="0,6,0,0" Foreground="{StaticResource Brush.TextSubtle}" FontSize="13"/>
              </StackPanel>
              <Button Grid.Column="1" x:Name="FavoriteButton" Content="☆ 收藏" Click="Favorite_Click" Padding="16,8"/>
              <Button Grid.Column="2" Content="编辑" Click="Edit_Click" Padding="16,8"/>
              <Button Grid.Column="3" Content="开始阅读" Click="Read_Click" Padding="22,8" Background="{StaticResource Brush.TextPrimary}" Foreground="{StaticResource Brush.Surface}"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Content="打开所在文件夹" Click="OpenFolder_Click" Padding="14,8"/>
              <Button Content="重新定位" Click="Relocate_Click" Padding="14,8"/>
              <Button x:Name="HideButton" Content="隐藏作品" Click="ToggleHidden_Click" Padding="14,8"/>
              <Button Content="删除库记录" Click="DeleteBook_Click" Padding="14,8" Background="{StaticResource Brush.DangerSurface}" Foreground="{StaticResource Brush.Danger}"/>
            </StackPanel>

            <ItemsControl x:Name="TagChips">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:TagChip">
                  <Border Margin="0,0,8,8" Padding="10,5" CornerRadius="14" Background="{Binding Color}">
                    <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#374151"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel>
              <TextBlock Text="简介" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource Brush.TextPrimary}"/>
              <TextBlock x:Name="SummaryText" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{StaticResource Brush.TextMuted}" LineHeight="22"/>
            </StackPanel>

            <Border x:Name="EditFormPanel" IsVisible="False" Padding="20" CornerRadius="10" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1">
              <StackPanel Spacing="14">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                  <TextBlock Text="编辑作品信息" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" VerticalAlignment="Center"/>
                  <Button Grid.Column="1" Content="取消" Click="CancelEdit_Click" Padding="16,8"/>
                  <Button Grid.Column="2" Content="保存" Click="SaveEdit_Click" Padding="16,8" Background="{StaticResource Brush.TextPrimary}" Foreground="{StaticResource Brush.Surface}"/>
                </Grid>
                <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                  <StackPanel Grid.Row="0">
                    <TextBlock Text="书名" Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBox x:Name="EditTitleBox" Margin="0,6,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="作者" Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBox x:Name="EditAuthorBox" Margin="0,6,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1">
                    <TextBlock Text="外文名" Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBox x:Name="EditForeignNameBox" Margin="0,6,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="角色名" Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBox x:Name="EditCharacterNameBox" Margin="0,6,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2">
                    <TextBlock Text="出品时间" Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBox x:Name="EditProducedAtBox" Margin="0,6,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Text="Tag" Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBox x:Name="EditTagsBox" Margin="0,6,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="3">
                    <TextBlock Text="封面页 / 阅读次数 / 状态" Foreground="{StaticResource Brush.TextMuted}"/>
                    <Grid ColumnDefinitions="*,10,*,10,*" Margin="0,6,0,0">
                      <NumericUpDown x:Name="EditCoverPageBox" Minimum="1" Increment="1"/>
                      <NumericUpDown Grid.Column="2" x:Name="EditReadCountBox" Minimum="0" Increment="1"/>
                      <ComboBox Grid.Column="4" x:Name="EditReadingStatusBox" SelectedIndex="0">
                        <ComboBoxItem Content="未读"/>
                        <ComboBoxItem Content="在读"/>
                      </ComboBox>
                    </Grid>
                  </StackPanel>
                  <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                    <TextBlock Text="简介" Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBox x:Name="EditSummaryBox" Margin="0,6,0,0" MinHeight="96" AcceptsReturn="True" TextWrapping="Wrap"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <StackPanel>
              <TextBlock Text="作品信息" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource Brush.TextPrimary}"/>
              <Grid Margin="0,12,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="96,*" RowSpacing="10" ColumnSpacing="16">
                <TextBlock Grid.Row="0" Text="作者" Foreground="#8D8177"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="MetaAuthorText"/>
                <TextBlock Grid.Row="1" Text="外文名" Foreground="#8D8177"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ForeignNameText"/>
                <TextBlock Grid.Row="2" Text="角色名" Foreground="#8D8177"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CharacterNameText"/>
                <TextBlock Grid.Row="3" Text="页数" Foreground="#8D8177"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PageCountText"/>
                <TextBlock Grid.Row="4" Text="封面页" Foreground="#8D8177"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CoverPageText"/>
                <TextBlock Grid.Row="5" Text="出品时间" Foreground="#8D8177"/>
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ProducedAtText"/>
                <TextBlock Grid.Row="6" Text="阅读次数" Foreground="#8D8177"/>
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="ReadCountText"/>
                <TextBlock Grid.Row="7" Text="文件体积" Foreground="#8D8177"/>
                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="SizeText"/>
                <TextBlock Grid.Row="8" Text="录入时间" Foreground="#8D8177"/>
                <TextBlock Grid.Row="8" Grid.Column="1" x:Name="ImportedAtText"/>
              </Grid>
            </StackPanel>

            <StackPanel>
              <TextBlock Text="文件" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource Brush.TextPrimary}"/>
              <TextBlock x:Name="FolderPathText" Margin="0,10,0,0" Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap"/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Grid>

      <Grid Grid.Row="1" x:Name="TagsPagePanel" IsVisible="False" Margin="22" RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
          <StackPanel>
            <TextBlock Text="标签" FontSize="28" FontWeight="Black" Foreground="{StaticResource Brush.TextWarm}"/>
            <TextBlock x:Name="TagManagerStatsText" Text="0 个" Foreground="{StaticResource Brush.TextMuted}"/>
          </StackPanel>
          <TextBox Grid.Column="1" x:Name="TagManagerSearchBox" Width="220" Watermark="搜索标签" TextChanged="TagManagerSearchBox_TextChanged"/>
          <TextBox Grid.Column="2" x:Name="NewTagNameBox" Width="160" Watermark="新增标签"/>
          <Button Grid.Column="3" Content="新增" Click="CreateTag_Click" Padding="16,8" Background="{StaticResource Brush.TextPrimary}" Foreground="{StaticResource Brush.Surface}"/>
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="*,12,160,12,160" ColumnSpacing="0">
          <TextBox x:Name="RenameTagNameBox" Watermark="选中标签的新名称"/>
          <TextBox Grid.Column="2" x:Name="RenameTagCategoryBox" Watermark="分组"/>
          <TextBox Grid.Column="4" x:Name="RenameTagColorBox" Watermark="#EFE5DA"/>
        </Grid>
        <ListBox Grid.Row="2" x:Name="TagManagerList" SelectionChanged="TagManagerList_SelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="local:TagManagerItem">
              <Border Padding="14" Margin="0,0,0,10" CornerRadius="10" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}"/>
                    <TextBlock Text="{Binding Summary}" Margin="0,4,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="12"/>
                  </StackPanel>
                  <Button Grid.Column="1" Content="筛选" Click="FilterByTag_Click" Padding="12,7"/>
                  <Button Grid.Column="2" Content="重命名" Click="RenameTag_Click" Padding="12,7"/>
                  <Button Grid.Column="3" Content="删除" Click="DeleteTag_Click" Padding="12,7" Background="{StaticResource Brush.DangerSurface}" Foreground="{StaticResource Brush.Danger}"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <Grid Grid.Row="1" x:Name="AuthorsPagePanel" IsVisible="False" Margin="22" RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
          <StackPanel>
            <TextBlock Text="作者" FontSize="28" FontWeight="Black" Foreground="{StaticResource Brush.TextWarm}"/>
            <TextBlock x:Name="AuthorManagerStatsText" Text="0 位" Foreground="{StaticResource Brush.TextMuted}"/>
          </StackPanel>
          <TextBox Grid.Column="1" x:Name="AuthorSearchBox" Width="220" Watermark="搜索作者" TextChanged="AuthorSearchBox_TextChanged"/>
          <Button Grid.Column="2" Content="新增作者" Click="CreateAuthor_Click" Padding="16,8" Background="{StaticResource Brush.TextPrimary}" Foreground="{StaticResource Brush.Surface}"/>
        </Grid>
        <TextBox Grid.Row="1" x:Name="RenameAuthorNameBox" Watermark="选中作者的新名称"/>
        <ListBox Grid.Row="2" x:Name="AuthorManagerList" SelectionChanged="AuthorManagerList_SelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="local:AuthorManagerItem">
              <Border Padding="14" Margin="0,0,0,10" CornerRadius="10" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}"/>
                    <TextBlock Text="{Binding Summary}" Margin="0,4,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="12"/>
                  </StackPanel>
                  <Button Grid.Column="1" Content="筛选" Click="FilterByAuthor_Click" Padding="12,7"/>
                  <Button Grid.Column="2" Content="重命名" Click="RenameAuthor_Click" Padding="12,7"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <Border Grid.Row="2" x:Name="LogPanel" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="0,1,0,0" Padding="16,10">
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
          <TextBlock Text="日志" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}"/>
          <Button Grid.Column="1" x:Name="ToggleLogButton" Content="扩大" Click="ToggleLog_Click" Height="32" Padding="14,0"/>
          <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" x:Name="LogScroll" Height="160">
            <TextBlock x:Name="LogText" TextWrapping="Wrap" Foreground="{StaticResource Brush.TextMuted}" FontSize="12"/>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
