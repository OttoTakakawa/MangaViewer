<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MangaReader.Avalonia.ReaderWindow"
        Width="1120"
        Height="820"
        MinWidth="760"
        MinHeight="560"
        Title="阅读器"
        Background="#111827"
        KeyDown="ReaderWindow_KeyDown">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="#0B1220" Padding="14" BorderBrush="#1F2937" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
        <Button Content="返回" Click="Close_Click" Padding="14,7"/>
        <Button Grid.Column="1" Content="上一页" Click="Previous_Click" Padding="14,7"/>
        <TextBlock Grid.Column="2" x:Name="TitleText" VerticalAlignment="Center" Foreground="#F9FAFB" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
        <TextBlock Grid.Column="3" x:Name="PageText" VerticalAlignment="Center" Foreground="#D1D5DB"/>
        <Button Grid.Column="4" Content="下一页" Click="Next_Click" Padding="14,7"/>
        <Button Grid.Column="5" Content="打开文件夹" Click="OpenFolder_Click" Padding="14,7"/>
      </Grid>
    </Border>
    <ScrollViewer Grid.Row="1" x:Name="ReaderScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
      <Grid MinHeight="520">
        <Image x:Name="PageImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBlock x:Name="PlaceholderText" Text="没有可显示的页面" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D1D5DB"/>
      </Grid>
    </ScrollViewer>
  </Grid>
</Window>
