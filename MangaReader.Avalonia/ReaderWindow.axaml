<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MangaReader.Avalonia.ReaderWindow"
        Width="1120"
        Height="820"
        MinWidth="760"
        MinHeight="560"
        Title="阅读器"
        Background="#111827"
        KeyDown="ReaderWindow_KeyDown">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="#0B1220" Padding="14" BorderBrush="#1F2937" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
        <Button Content="返回" Click="Close_Click" Padding="14,7"/>
        <Button Grid.Column="1" Content="上一页" Click="Previous_Click" Padding="14,7"/>
        <TextBlock Grid.Column="2" x:Name="TitleText" VerticalAlignment="Center" Foreground="#F9FAFB" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
        <TextBlock Grid.Column="3" x:Name="PageText" VerticalAlignment="Center" Foreground="#D1D5DB"/>
        <ComboBox Grid.Column="4" x:Name="ReadingModeBox" Width="86" SelectedIndex="0" SelectionChanged="ReaderOption_Changed">
          <ComboBoxItem Content="单页"/>
          <ComboBoxItem Content="双页"/>
        </ComboBox>
        <ComboBox Grid.Column="5" x:Name="FitModeBox" Width="92" SelectedIndex="1" SelectionChanged="ReaderOption_Changed">
          <ComboBoxItem Content="适宽"/>
          <ComboBoxItem Content="适高"/>
          <ComboBoxItem Content="原始"/>
        </ComboBox>
        <Slider Grid.Column="6" x:Name="ZoomSlider" Width="130" Minimum="0.1" Maximum="3" Value="1" TickFrequency="0.1" ValueChanged="ZoomSlider_ValueChanged"/>
        <Button Grid.Column="7" Content="下一页" Click="Next_Click" Padding="14,7"/>
        <Button Grid.Column="8" Content="打开文件夹" Click="OpenFolder_Click" Padding="14,7"/>
      </Grid>
    </Border>
    <ScrollViewer Grid.Row="1" x:Name="ReaderScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" SizeChanged="ReaderScrollViewer_SizeChanged">
      <Grid MinHeight="520" Margin="24">
        <StackPanel x:Name="PageHost" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Image x:Name="PageImageLeft" Stretch="Uniform"/>
          <Image x:Name="PageImageRight" Stretch="Uniform"/>
        </StackPanel>
        <TextBlock x:Name="PlaceholderText" Text="没有可显示的页面" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D1D5DB"/>
      </Grid>
    </ScrollViewer>
  </Grid>
</Window>
